COMMENT ON COLUMN "OWNBT_OUT"."OUT_LEO_DISP_V"."UTDISP_OBCHODNI_PARTNER_ZAKAZNIK" IS 'Zákaznické číslo obchodního partnera (zákazník)';
COMMENT ON COLUMN "OWNBT_OUT"."OUT_LEO_DISP_V"."UTDISP_MLVL_L1" IS 'MLVL úroveň L1';
COMMENT ON COLUMN "OWNBT_OUT"."OUT_LEO_DISP_V"."UTDISP_MLVL_L2" IS 'MLVL úroveň L2 - kategorizace podle typu obchodního případu';
COMMENT ON COLUMN "OWNBT_OUT"."OUT_LEO_DISP_V"."UTDISP_MLVL_L3" IS 'MLVL úroveň L3 - kód kategorie úkolu (L3)';

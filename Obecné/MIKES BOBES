COMMENT ON COLUMN "OWNBT_OUT"."OUT_LEO_DISP_V"."UTDISP_SMER" IS 'Směr záznamu (kód)';
COMMENT ON COLUMN "OWNBT_OUT"."OUT_LEO_DISP_V"."UTDISP_KANAL_PREVZETI" IS 'Kód kanálu převzetí (např. 31)';

def findFolderRecursive(parent, folderName) {
    def subFolders = (parent instanceof OdiProject) ? parent.getFolders() : parent.getSubFolders()
    def found = subFolders.find { it.getName().equalsIgnoreCase(folderName) }
    if (found) return found
    for (subFolder in subFolders) {
        def result = findFolderRecursive(subFolder, folderName)
        if (result) return result
    }
    return null
}

def tm = odiInstance.getTransactionManager()
def t_man = odiInstance.getTransactionalEntityManager()
def txn = tm.getTransaction(new DefaultTransactionDefinition())

try {
    def projFinder = (IOdiProjectFinder) t_man.getFinder(OdiProject.class)
    def dsFinder = (IOdiDataStoreFinder) t_man.getFinder(OdiDataStore.class)
    def project = projFinder.findByCode(targetProjectCode)
    def folder = findFolderRecursive(project, targetFolderName)
    def targetIKM = project.getIKMs().find { it.getName() == ikmName }
    if (targetIKM == null) { println "VAROVÁNÍ: IKM ${ikmName} nenalezen" }

    if (!folder) { println "CHYBA: Složka ${targetFolderName} nenalezena"; return }

    mapList.each { row ->
        def mapName = row[0]; def srcName = row[1]; def tgtName = row[2]
        println "--- Zpracovávám: ${mapName} ---"

        try {
            def map = folder.getMappings().find { it.getName() == mapName }
            if (map == null) {
                println "    [INFO] Mapping ${mapName} neexistuje, vytvářím nový"
                map = new Mapping(mapName, folder)
                t_man.persist(map)  // Persistujeme ihned po vytvoření
            } else {
                println "    [INFO] Mapping ${mapName} nalezen, čistím komponenty"
                if (map.getComponents().size() > 0) {
                    map.getComponents().each { map.removeComponent(it) }
                }
            }

            def srcDS = dsFinder.findByName(srcName, sourceModelName).iterator().next()
            def tgtDS = dsFinder.findByName(tgtName, targetModelName).iterator().next()

            def srcComp = new DatastoreComponent(map, srcDS)
            def tgtComp = new DatastoreComponent(map, tgtDS)
            map.addComponent(srcComp)
            map.addComponent(tgtComp)
            
            // Vytvoření filtru pomocí reflection (jako v IT_OT a IKM)
            def clFiltComp = Class.forName("oracle.odi.domain.mapping.component.FilterComponent")
            def filter = clFiltComp.constructors.find { it.parameterTypes.size() == 2 && it.parameterTypes[1] == String.class }.newInstance(map, "FILTER")
            
            srcComp.getOutputConnectorPoints()[0].connectTo(filter.getInputConnectorPoints()[0])
            filter.getOutputConnectorPoints()[0].connectTo(tgtComp.getInputConnectorPoints()[0])
            
            // Nastavení filtru
            filter.setFilterCondition("${srcComp.getName()}.EFFECTIVE_DATE = #VAR_EFFECTIVE_DATE")

            // LOGIKA MAPPINGU ATRIBUTŮ - SCD2 Slowly Changing Dimension
            tgtComp.getAttributes().each { targetAttr ->
                def name = targetAttr.getName()
                def expr = ""
                def tNameUpper = name.toUpperCase()
                
                // Získáme kód tabulky z názvu (např. BTDQ z INT_OTBTDQ_SD)
                def tableCode = mapName.replace("INT_OT", "").replace("_SD", "")
                
                // SCD2 Klíč (ORIG_ID jako INDEX)
                if (name == "OT${tableCode}_ORIG_ID") {
                    try { 
                        targetAttr.setIndicator("INDEX", true) 
                    } catch(e) { 
                        try { 
                            targetAttr.setPropertyValue("INDICATOR_KEY", true) 
                        } catch(e2) {} 
                    }
                }

                // Nastavení výrazů podle typu sloupce
                if (name == "OT${tableCode}_ID") {
                    // Primární klíč ze sekvence
                    expr = ":${targetProjectCode}.OT${tableCode}_ID_SEQ.NEXTVAL"
                }
                else if (name == "OT${tableCode}_ORIG_ID") {
                    // ORIG_ID z ID zdrojové tabulky
                    expr = "${srcComp.getName()}.${tableCode}_ID"
                }
                else if (tNameUpper.contains("CREATED_DATE") || tNameUpper.contains("MODIFIED_DATE")) {
                    expr = "SYSDATE"
                }
                else if (tNameUpper.contains("VALID_FROM")) {
                    expr = "#VAR_EFFECTIVE_DATE"
                }
                else if (tNameUpper.contains("VALID_TO")) {
                    expr = "30001231"
                }
                else if (tNameUpper.contains("CURRENT_FLAG")) {
                    expr = "0"
                }
                else if (tNameUpper.contains("PROCESS")) {
                    expr = "<%=odiRef.getSession(\"SESS_NO\")%>"
                }
                else if (tNameUpper.contains("EFFECTIVE_DATE")) {
                    expr = "#BICPR_BT_DWH.VAR_EFFECTIVE_DATE"
                    targetAttr.setPropertyValue("EXECUTE_ON_HINT", "TARGET")
                    targetAttr.setInsertIndicator(true)
                    targetAttr.setUpdateIndicator(true)
                    println "    [SCD] ${name} -> VAR_EFFECTIVE_DATE s Insert/Update"
                }
                else {
                    // Přímé mapování ostatních atributů
                    def base = name.replace("OT${tableCode}_", "")
                    def srcAttr = srcComp.getAttributes().find { 
                        it.getName().toUpperCase() == base || 
                        it.getName().toUpperCase().endsWith("_" + base) ||
                        it.getName().toUpperCase() == "${tableCode}_${base}".toUpperCase()
                    }
                    if (srcAttr) {
                        expr = "${srcComp.getName()}.${srcAttr.getName()}"
                    }
                }
                
                if (expr) {
                    targetAttr.setExpressionText(expr)
                    targetAttr.setPropertyValue("EXECUTE_ON_HINT", "TARGET")
                }
            }

            // FYZICKÁ ÚROVEŇ (IKM a Parametry)
            map.getPhysicalDesigns().each { phys ->
                phys.getPhysicalNodes().each { node ->
                    if (node.isTargetNode()) {
                        if (targetIKM) node.setIKM(targetIKM)

                        // Nastavení parametrů IKM pro SCD
                        node.getIKMOptionValues().each { opt ->
                            def n = opt.getName()
                            if (n == "FLOW_CONTROL") opt.setValue(false)
                            if (n == "UPDATE" || n == "DELETE") opt.setValue(false)
                            if (n == "INSERT" || n == "COMMIT") opt.setValue(true)
                        }
                    }
                }
            }
            t_man.persist(map)
            println "    [OK] Mapping uložen"
        } catch (Exception ex) {
            println "    [CHYBA] ${ex.message}"
        }
    }
    tm.commit(txn)
    println "--- HOTOVO ---"
} catch (e) {
    if (txn) tm.rollback(txn)
    e.printStackTrace()
}

def findFolderRecursive(parent, folderName) {
    def subFolders = (parent instanceof OdiProject) ? parent.getFolders() : parent.getSubFolders()
    def found = subFolders.find { it.getName().equalsIgnoreCase(folderName) }
    if (found) return found
    for (subFolder in subFolders) {
        def result = findFolderRecursive(subFolder, folderName)
        if (result) return result
    }
    return null
}

def tm = odiInstance.getTransactionManager()
def t_man = odiInstance.getTransactionalEntityManager()
def txn = tm.getTransaction(new DefaultTransactionDefinition())

try {
    def projFinder = (IOdiProjectFinder) t_man.getFinder(OdiProject.class)
    def dsFinder = (IOdiDataStoreFinder) t_man.getFinder(OdiDataStore.class)
    def project = projFinder.findByCode(targetProjectCode)
    def folder = findFolderRecursive(project, targetFolderName)
    def targetIKM = project.getIKMs().find { it.getName() == ikmName }
    if (targetIKM == null) { println "VAROVÁNÍ: IKM ${ikmName} nenalezen" }

    if (!folder) { println "CHYBA: Složka ${targetFolderName} nenalezena"; return }

    mapList.each { row ->
        def mapName = row[0]; def srcName = row[1]; def tgtName = row[2]
        println "--- Zpracovávám: ${mapName} ---"

        try {
            def map = folder.getMappings().find { it.getName() == mapName }
            if (map == null) {
                println "    [INFO] Mapping ${mapName} neexistuje, vytvářím nový"
                map = new Mapping(mapName, folder)
            } else {
                println "    [INFO] Mapping ${mapName} nalezen, čistím komponenty"
                if (map.getComponents().size() > 0) {
                    map.getComponents().each { map.removeComponent(it) }
                }
            }

            def srcDS = dsFinder.findByName(srcName, sourceModelName).iterator().next()
            def tgtDS = dsFinder.findByName(tgtName, targetModelName).iterator().next()

            def srcComp = new DatastoreComponent(map, srcDS)
            def tgtComp = new DatastoreComponent(map, tgtDS)
            map.addComponent(srcComp)
            map.addComponent(tgtComp)
            srcComp.getOutputConnectorPoints()[0].connectTo(tgtComp.getInputConnectorPoints()[0])

            // LOGIKA MAPPINGU ATRIBUTŮ (Prefixy IT_ vs ATOT_)
            tgtComp.getAttributes().each { targetAttr ->
                def tNameUpper = targetAttr.getName().toUpperCase()
                
                if (tNameUpper.contains("EFFECTIVE_DATE")) {
                    targetAttr.setExpressionText("#BICPR_BT_DWH.VAR_EFFECTIVE_DATE")
                    targetAttr.setPropertyValue("EXECUTE_ON_HINT", "TARGET")
                    
                    // Nastavení Insert/Update - toto funguje
                    targetAttr.setInsertIndicator(true)
                    targetAttr.setUpdateIndicator(true)
                    println "    [UD1] Nastaveno Insert/Update pro ${targetAttr.getName()}"
                    
                    // POZNÁMKA: UD1 (User Defined Flag 1) nelze nastavit přes Groovy API
                    // ve vaší verzi ODI. Je nutné nastavit manuálně:
                    // 1. Otevřete mapping v ODI Studio
                    // 2. Přejděte na záložku "Logical"
                    // 3. Najděte atribut EFFECTIVE_DATE
                    // 4. Zaškrtněte "UD 1" checkbox
                    // 5. Uložte mapping
                } 
                else if (tNameUpper.contains("CREATED_DATE")) {
                    targetAttr.setExpressionText("SYSDATE")
                    targetAttr.setPropertyValue("EXECUTE_ON_HINT", "TARGET")
                } 
                else if (true) {
                    // Odstranění prefixů pro párování (např. ITBTDQ_ID vs ATOT_BTDQ_ID)
                    // Zde se pokusí najít shodu podle zbytku názvu za prvním podtržítkem
                    def targetSuffix = tNameUpper.contains("_") ? tNameUpper.substring(tNameUpper.indexOf("_")) : tNameUpper
                    def sAttr = srcComp.getAttributes().find { 
                        def sName = it.getName().toUpperCase()
                        def sourceSuffix = sName.contains("_") ? sName.substring(sName.indexOf("_")) : sName
                        return targetSuffix == sourceSuffix
                    }
                    
                    if (sAttr) {
                        targetAttr.setExpressionText(srcComp.getName() + "." + sAttr.getName())
                    }
                }
            }

            // FYZICKÁ ÚROVEŇ (IKM a Parametry)
            map.getPhysicalDesigns().each { phys ->
                phys.getPhysicalNodes().each { node ->
                    if (node.isTargetNode()) {
                        if (targetIKM) node.setIKM(targetIKM)

                        // POZNÁMKA: UD1 na fyzické úrovni nelze nastavit přes Groovy API
                        // IKM option "DROP_PARTITION_BY_CONDITION_UD1" je nastaven výše

                        // Nastavení parametrů IKM dle projektu ADAPTACE
                        node.getIKMOptionValues().each { opt ->
                            def n = opt.getName()
                            if (n == "UPDATE" || n == "STATIC_CONTROL" || n == "TRUNCATE") opt.setValue(false)
                            if (n == "DROP_PARTITION_BY_CONDITION_UD1" || n == "INSERT" || n == "COMMIT") opt.setValue(true)
                        }
                    }
                }
            }
            t_man.persist(map)
            println "    [OK] Mapping uložen"
        } catch (Exception ex) {
            println "    [CHYBA] ${ex.message}"
        }
    }
    tm.commit(txn)
    println "--- HOTOVO ---"
} catch (e) {
    if (txn) tm.rollback(txn)
    e.printStackTrace()
}
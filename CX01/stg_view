        from (

SELECT 
  xccpro_key as UTLEOS_xccpro_key,
xccpro_filename_templ||'_'||replace(xccpro_filename_key,'YYYYMMDD',to_char(xccpro_filename_date,'YYYYMMDD'))     as utleos_export_filename,
        (CASE   WHEN DDOBAA_TYP_PUVODNI = 'FVE' THEN '1080000'||DDOBAA_HLAVNI_OBCHODNI_PRIPAD_ID
                WHEN DDOBAA_TYP_PUVODNI = 'TEPC' THEN '2180000'||DDOBAA_HLAVNI_OBCHODNI_PRIPAD_ID ELSE null END) as utleos_id ,
 to_char(xccpro_process_date,'YYYYMMDD') as utleos_effective_date,

        (CASE   WHEN DDOBAA_TYP_PUVODNI = 'FVE' THEN '1080000'||DDOBAA_HLAVNI_OBCHODNI_PRIPAD_ID
                WHEN DDOBAA_TYP_PUVODNI = 'TEPC' THEN '2180000'||DDOBAA_HLAVNI_OBCHODNI_PRIPAD_ID ELSE null END) AS UTLEOS_D_ACTIVIT, 
        DDOBAA_HLAVNI_OBCHODNI_PRIPAD_ID AS UTLEOS_D_ID_OBJ,
        to_char (to_date (DDOBAA_BG_SMLOUVA_PODEPSANA_KDY), 'YYYYMMDD') AS UTLEOS_D_ERDAT,
        to_char (to_date (DDOBPA_MONTAZ_KONEC), 'YYYYMMDD') AS UTLEOS_D_DATUZA,
        (CASE WHEN DDOBAA_TYP_PUVODNI = 'FVE' THEN 'FVE1' WHEN DDOBAA_TYP_PUVODNI = 'TEPC' THEN 'TCP1' ELSE 'JINE' END) AS UTLEOS_D_CCATID1, 
        (CASE WHEN DDOBAA_TYP_UPRAVENY = 'TEPC' THEN 'TCP2' ELSE 'FVE2' END) AS UTLEOS_D_CCATID2, 
        DDOBAA_ORIG_D_PARTNER AS UTLEOS_D_PARTNER, 
        NVL (DSM_BPAR_MV.TELEFON_ZASMLUVNENY, DSM_BPAR_MV.TELEFON_POTVRZENY) AS UTLEOS_AD02_TEL,
        (CASE WHEN DSM_BPAR_MV.DFGDPA_STBPAC_ACTIVE_ELE = 1 THEN 'X' ELSE null END) AS UTLEOS_D_ELE_FL,
        (CASE WHEN DSM_BPAR_MV.DFGDPA_STBPAC_ACTIVE_PLN = 1 THEN 'X' ELSE null END) AS UTLEOS_D_PLY_FL,
        NULL AS UTLEOS_D_TELNVO, 
        NVL(DSM_BPAR_MV.EMAIL_ZASMLUVNENY, DSM_BPAR_MV.EMAIL_POTVRZENY) AS UTLEOS_EMAIL,
        DDOBPA_PARTNER_PRO_NAVSTEVU AS UTLEOS_D_ZALOZIL_D_USER,
        DDOBPA_PARTNER_PRO_REALIZACI AS UTLEOS_D_RESITEL_D_USER,
        DSM_BPAR_MV.DDBPAR_NAZEV AS UTLEOS_DDBPAR_NAZEV,
        (CASE WHEN NVL (REKLAMACE_FVE,0) + NVL (REKLAMACE_TEPC,0) > 0 THEN 1 ELSE 0 END) AS UTLEOS_ODHAD_SPOTREBY, 
        to_char (ADD_MONTHS (trunc (DDOBAA_BG_REALIZOVANO_KDY),18), 'YYYYMMDD') AS UTLEOS_ROZHODNE_DATUM, 
        decode(ddbpar_D_OSL_DOP,'N/A',null,ddbpar_D_OSL_DOP) as UTLEOS_D_OSL_DOP,
        (CASE WHEN DDBPAR_POHLAVI = 'M' THEN '1' WHEN DDBPAR_POHLAVI = 'Z' THEN '2' ELSE 'N/A' END) AS UTLEOS_POHLAVI
FROM OWNBT_DWH.DOD_OBAL_ACTL

LEFT JOIN OWNBT_DWH.DOD_OBPR_ACTL ON DDOBAA_HLAVNI_OBCHODNI_PRIPAD_ID = DDOBPA_OBCHODNI_PRIPAD_ID
LEFT JOIN OWNBT_DTM.DSM_BPAR_MV ON DDOBAA_ORIG_D_PARTNER = DDBPAR_D_PARTNER

LEFT JOIN otevrena_reklamace ON DDOBAA_ORIG_D_PARTNER = OP_OTEVRENA_REKLAMACE


LEFT JOIN Historicka_reklamace ON DDOBAA_ORIG_D_PARTNER = OP_REKLAMACE_V_MINULOSTI

    left join OWNBT_STG.sut_cx01_zzz_sub_email_01_mv email  on DDOBAA_ORIG_D_PARTNER = email.Partner_email_hlavni

    left join OWNBT_STG.sut_cx01_zzz_sub_tel_01_mv tel    on DDOBAA_ORIG_D_PARTNER = tel.Partner_telefon_hlavni

    left join OWNBT_STG.sut_cx01_zzz_sub_gdpr_01_mv GDPR    on DDOBAA_ORIG_D_PARTNER = GDPR.ddbpar_d_partner


CROSS JOIN xfc 

WHERE   1=1

       AND ADD_MONTHS (trunc (DDOBAA_BG_REALIZOVANO_KDY),18) = trunc(xccpro_process_date + round(xccpro_date_offset_from,0)) -1 

        AND DDOBAA_TEST_IND = 0         --bez testovacich OP  

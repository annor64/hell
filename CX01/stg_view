OTSS01_D_PARTNER as UTSS01_D_PARTNER,
TEL.TELEFON_HLAVNI as UTSS01_AD02_TEL,
email.email_hlavni as UTSS01_EMAIL,
case when otss01_d_crm_uzs like 'ZS_CS_0003' then  ODP.ODUSER_D_USER
     when otss01_d_crm_uzs like 'ZS_CS_0005' then  zal.ODUSER_D_USER
     else GT_DODAVATEL.otsv01_d_csv_val  end as UTSS01_D_ZALOZIL,
zal.ODUSER_D_USER as UTSS01_D_RESITEL,  -- nove upraveno 16.7.2021 zmenen vstup a i nazev sloupecku.
OTSS01_D_CRM_UZS as UTSS01_D_CRM_UZS,
DDBPAR_NAZEV as UTSS01_DDBPAR_NAZEV,
CASE 
WHEN otss01_d_crm_uzs = 'ZS_CSV0006' THEN 'I08' 
ELSE  
    CASE WHEN OTSS01_D_KANAL = '26' THEN 'I04'  
         WHEN OTSS01_D_KANAL = '01' THEN 'I01'  
         WHEN OTSS01_D_KANAL = '04' THEN 'I01'  
         WHEN OTSS01_D_KANAL = '03' THEN 'I02'  
         WHEN OTSS01_D_KANAL = '07' THEN 'I03'
         WHEN OTSS01_D_KANAL = '37' THEN 'I09'  
         ELSE '' 
    END 
END as UTSS01_ID_KPI,
DATE_ROZHODNE_DATUM as UTSS01_ROZHODNE_DATUM,
UTSS01_D_CCATID1,
UTSS01_D_CCATID2,
UTSS01_D_CCATID3,
DDBPAR_D_OSL_DOP as UTSS01_D_OSL_DOP,
decode(ddbpar_pohlavi,'M','1','Z','2','N',null,ddbpar_pohlavi) as UTSS01_POHLAVI,
CASE WHEN otss01_d_crm_uzs = 'ZS_CSV0006' THEN '1' ELSE '2' END as UTSS01_VARIANTA,
row_number() over (partition by OTSS01_D_PARTNER order by OTSS01_ID desc ) as rn -- kdyby se nahodou chtel clovek za jeden den vygenerovat vicekrat.
from
    GT_STATUSY ss01
    INNER JOIN ownbt_dwh.dsd_bpar bpar
        ON ss01.otss01_d_partner = bpar.ddbpar_d_partner and  ddbpar_current_flag = 1
    INNER JOIN ownbt_ods.odd_user_v zal
        ON (zal.oduser_d_bp_user = ss01.OTSS01_D_ZALOZIL and ss01.OTSS01_D_ZALOZIL <> 'N/A' )

     LEFT OUTER JOIN ownbt_ods.odd_user_v ODP
        ON (ODP.oduser_d_bp_user = ss01.OTSS01_D_ODPOVH  )

    left JOIN OWNBT_STG.sut_cx01_zzz_sub_tel_01_mv tel    
        on ss01.otss01_d_partner   = tel.Partner_telefon_hlavni

    left join OWNBT_STG.sut_cx01_zzz_sub_email_01_mv email  
        on ss01.otss01_d_partner  = email.Partner_email_hlavni

    LEFT OUTER JOIN  GT_DODAVATEL 
        ON (GT_DODAVATEL.otsv01_d_crm_shs = ss01.OTSS01_D_CRM_SHS) and   nvl(ss01.otss01_d_aedat, to_Date('1900-01-01','YYYY-MM-DD')) between to_Date(GT_DODAVATEL.otsv01_valid_from,'YYYYMMDD') and to_Date(GT_DODAVATEL.otsv01_valid_to,'YYYYMMDD')


    left join OWNBT_STG.sut_cx01_zzz_sub_gdpr_01_mv GDPR    
        on OTSS01_D_PARTNER = GDPR.ddbpar_d_partner
where 1 = 1
and 
        OTSS01_D_KANAL IN ('01','03','07','26','04','37')
    and OTSS01_D_ZALOZIL NOT IN ('0004008112','0004012128','0004011460','0004012113','0004004792')
    and OTSS01_D_PARTNER NOT IN ('0020232450','0014148145','0020237525','0010405135','0020232438','0020234065','0020232701')
    and not (UTSS01_D_CCATID1='990000' and ODP.ODUSER_D_USER ='N/A')
    -- nema GDPR omezeni
    and GDPR.ddbpar_d_partner is null

) where rn = 1

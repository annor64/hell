  CREATE OR REPLACE FORCE EDITIONABLE VIEW "OWNBT_STG"."SUT_CX01_AKVI_01_INIT_V" ("UTAKVI_XCCPRO_KEY", "UTAKVI_EXPORT_FILENAME", "UTAKVI_ID", "UTAKVI_EFFECTIVE_DATE", "UTAKVI_D_CRM_LEA", "UTAKVI_D_ID_OBJ", "UTAKVI_D_ERDAT", "UTAKVI_D_DATUZA", "UTAKVI_TIMEZAL", "UTAKVI_D_CCATID1", "UTAKVI_D_CCATID2", "UTAKVI_D_DIRECT", "UTAKVI_D_KANAL", "UTAKVI_D_ELE_FL", "UTAKVI_D_PARTNER", "UTAKVI_AD02_TEL", "UTAKVI_D_PLY_FL", "UTAKVI_D_TELNVO", "UTAKVI_EMAIL", "UTAKVI_ADRESA_ULICE", "UTAKVI_ADRESA_CP", "UTAKVI_ADRESA_CO", "UTAKVI_ADRESA_MISTO", "UTAKVI_ADRESA_MISTNI_CAST", "UTAKVI_ADRESA_PSC", "UTAKVI_ZALOZIL_D_USER", "UTAKVI_D_RESITEL_D_USER", "UTAKVI_POCET_RESITELU", "UTAKVI_D_CRM_UZS", "UTAKVI_DDBPAR_NAZEV", "UTAKVI_BONITA", "UTAKVI_SEGMENTACE", "UTAKVI_POCET_MS", "UTAKVI_ODHAD_SPOTREBY", "UTAKVI_HODNOTA_ZAKAZNIKA", "UTAKVI_PRACOVISTE", "UTAKVI_ID_KPI", "UTAKVI_VLASTNIK_DAT", "UTAKVI_ROZHODNE_DATUM", "UTAKVI_D_CCATID3", "UTAKVI_D_MOB_FL", "UTAKVI_D_OSL_DOP", "UTAKVI_POHLAVI", "UTAKVI_VARIANTA") AS 
  WITH GT_VAZB AS (
select X_D_CRM_LEA, akvi_id_balicku,akvi_partner
from 
(
    select dfvazb_source_d_crm_lea as X_D_CRM_LEA , dfvazb_akvi_id_balicku as akvi_id_balicku, dfvazb_source_d_partner as akvi_partner  from ownbt_dwh.dlf_vazb where dfvazb_current_flag  = 1
    and dfvazb_akvi_id_balicku <> 'N/A'
    union
    select dfvazb_target_d_crm_lea, dfvazb_akvi_id_balicku, dfvazb_source_d_partner  from ownbt_dwh.dlf_vazb where dfvazb_current_flag  = 1

  CREATE OR REPLACE FORCE EDITIONABLE VIEW "OWNBT_STG"."SUT_CX01_CL04_01_INIT_V" ("UTCL04_D_PARTNER", "UTCL04_BPAR_NAZEV", "UTCL04_COL_USER", "UTCL04_DATE_VALID", "UTCL04_TIME_VALID", "UTCL04_D_ID_OBJ", "UTCL04_D_XCATID1", "UTCL04_D_XCATID2", "UTCL04_D_XCATID3", "UTCL04_D_KANAL", "UTCL04_D_ZALOZIL", "UTCL04_D_RESITEL", "UTCL04_RESPONSE_1", "UTCL04_RESPONSE_2", "UTCL04_RESPONSE_3", "UTCL04_RESPONSE_4") AS 
  WITH GT_COL_BASE as ( 
    select 
    OTCL04_D_PARTNER,
    OTCL04_D_COLJKEY,
    OTCL04_VALID_FROM,
    OTCL04_EMAIL_ADDR,
    OTCL04_D_USERPOR as COL_UZIVATEL,
    otcl04_D_DCLCREA,
    otcl04_D_TCLCREA,
    otcl04_D_ID_OBJ,

    otcl04_D_KANAL,
    otcl04_D_ZAL_U,
    case when otcl04_D_ZME_U = 'N/A' then null else otcl04_D_ZME_U end as otcl04_D_ZME_U ,
    OTCL04_D_COLTYPA,
    OTCL04_D_CLCNFNN,
    OTCL04_D_CLCNFNO,
    OTCL04_D_CLMSGT,
    OTCL04_D_CCATID3
    from
    ownbt_ods.odt_cl04 
    where  
    otcl04_d_coljkey <> 'N/A' and -- spojovací klíč vyplněn 
    otcl04_d_partner <> 'N/A' and -- partner vyplněn
    OTCL04_CURRENT_FLAG = 1 -- aktuální stav dat
    AND trunc(OTCL04_D_DCLCREA) > trunc(sysdate-6)
),

--- výsledný dotazník --
GT_FIN_QUEST AS (
    select
    bas.OTCL04_D_PARTNER,
    bas.OTCL04_D_DCLCREA,
    bas.OTCL04_D_TCLCREA,
    bas.OTCL04_D_ID_OBJ,
    bas.OTCL04_D_KANAL,
    bas.OTCL04_D_ZAL_U,
    bas.otcl04_D_ZME_U,
    bas.OTCL04_D_CCATID3,
    --col_uzivatel
    MAX(CASE WHEN bass.OTCL04_D_CLCNFNN = '01_00_DEFA' THEN substr(OTCL04_D_CLCNFNO,-1) ELSE NULL END) as RESPONSE_1,
    MAX(CASE WHEN bass.OTCL04_D_CLCNFNN = '02_00_DEFA' THEN substr(OTCL04_D_CLCNFNO,-1) ELSE NULL END) as RESPONSE_2,
    MAX(CASE WHEN bass.OTCL04_D_CLCNFNN = '03_00_DEFA' THEN substr(OTCL04_D_CLCNFNO,-1) ELSE NULL END) as RESPONSE_3,
    MAX(CASE WHEN bass.OTCL04_D_CLCNFNN = '04_00_DEFA' THEN OTCL04_D_CLMSGT ELSE NULL END) as RESPONSE_4
    from 
    (
        select 
        bas.OTCL04_D_PARTNER,
        bas.OTCL04_D_COLJKEY,
        bas.OTCL04_D_DCLCREA,
        bas.OTCL04_D_ID_OBJ,
        bas.OTCL04_D_KANAL,
        bas.OTCL04_D_ZAL_U,
        bas.otcl04_D_ZME_U,
        bas.OTCL04_D_CCATID3,
        max(bas.otcl04_D_TCLCREA) as otcl04_D_TCLCREA
        from GT_COL_BASE bas
        group by 
        bas.OTCL04_D_PARTNER,
        bas.OTCL04_D_COLJKEY,
        bas.OTCL04_D_DCLCREA,
        bas.OTCL04_D_ID_OBJ,
        bas.OTCL04_D_KANAL,
        bas.OTCL04_D_ZAL_U,
        bas.otcl04_D_ZME_U,
        bas.OTCL04_D_CCATID3
    ) bas
    INNER JOIN 
    GT_COL_BASE bass
    ON (bas.OTCL04_D_COLJKEY = bass.OTCL04_D_COLJKEY and bas.OTCL04_D_PARTNER = bass.OTCL04_D_PARTNER )
    GROUP BY
    bas.OTCL04_D_PARTNER,
    bas.OTCL04_D_DCLCREA,
    bas.OTCL04_D_TCLCREA,
    bas.OTCL04_D_ID_OBJ,
    bas.OTCL04_D_KANAL,
    bas.OTCL04_D_ZAL_U,
    bas.otcl04_D_ZME_U,
    bas.OTCL04_D_CCATID3
),

--- kategorire NO / TICKETU 

GT_CATEG AS (
    select
    b.OTCL04_D_ID_OBJ,
    nvl(ac01.otac01_d_ccatid1, ti01.OTTI01_D_TCATID1) as XCATID1,
    nvl(ac01.otac01_d_ccatid2, ti01.OTTI01_D_TCATID2) as XCATID2,
    nvl(ac01.otac01_d_ccatid3, ti01.OTTI01_D_TCATID3) as XCATID3,
    case when ac01.OTAC01_D_ID_OBJ is not null then 'AC' else 'TI' end as CATG_TYPE,
    nvl(oduser_d_user,otti01_d_odpov_kpjm) as userKPJM
    from 
    GT_FIN_QUEST  b
    LEFT OUTER JOIN 
    (
    select OTAC01_D_ID_OBJ, otac01_d_ccatid1, otac01_d_ccatid2, otac01_d_ccatid3, otac01_d_zalozil, otac01_d_resitel,
    odd_user_v2.oduser_d_user         
    from ownbt_ods.odt_ac01 
        join ownbt_ods.odd_user_v	odd_user_v2 on odd_user_v2.oduser_d_bp_user = otac01_d_resitel
        where OTAC01_CURRENT_FLAG = 1 and otac01_d_ccatid1 <> 'N/A' and otac01_d_ccatid2 <> 'N/A' and otac01_d_ccatid3 <> 'N/A'

    ) ac01
    ON ( ac01.OTAC01_D_ID_OBJ = b.OTCL04_D_ID_OBJ  )
    LEFT OUTER JOIN 
    (select OTTI01_D_ID_OBJ, OTTI01_D_TCATID1, OTTI01_D_TCATID2, OTTI01_D_TCATID3, otti01_d_zalozil , otti01_d_odpov ,otti01_d_odpov_kpjm 
    from ownbt_ods.odt_ti01 where OTTI01_CURRENT_FLAG = 1 and OTTI01_D_TCATID1 <> 'N/A' and OTTI01_D_TCATID2 <> 'N/A'  ) ti01
    ON (ti01.OTTI01_D_ID_OBJ = b.OTCL04_D_ID_OBJ )
    where b.OTCL04_D_ID_OBJ <> 'N/A'
)  

-- GRANDE FINALE -- toto výstupu pro IPSOS
select 
UTCL04_D_PARTNER,
UTCL04_BPAR_NAZEV,
CAST(NULL as varchar(50)) as UTCL04_COL_USER,
UTCL04_DATE_VALID,
UTCL04_TIME_VALID,
case when OTCL04_D_CCATID3 = 'V063' or ( OTCL04_D_CCATID3 = 'K061' and UTCL04_D_ID_OBJ ='N/A') then to_char(9999999999 -UTCL04_poradi) else UTCL04_D_ID_OBJ end  as UTCL04_D_ID_OBJ,
case when OTCL04_D_CCATID3 = 'V063' then 'L046' when OTCL04_D_CCATID3 = 'K061' and UTCL04_D_ID_OBJ ='N/A' then 'L140' else UTCL04_D_XCATID1 end as  UTCL04_D_XCATID1,
case when OTCL04_D_CCATID3 = 'V063' then 'L051' when OTCL04_D_CCATID3 = 'K061' and UTCL04_D_ID_OBJ ='N/A' then 'L141' else UTCL04_D_XCATID2 end as  UTCL04_D_XCATID2,
case when OTCL04_D_CCATID3 = 'V063' then 'V063' when OTCL04_D_CCATID3 = 'K061' and UTCL04_D_ID_OBJ ='N/A' then 'K999' else UTCL04_D_XCATID3 end as  UTCL04_D_XCATID3,
UTCL04_D_KANAL,
UTCL04_D_ZALOZIL,
userKPJM as UTCL04_D_RESITEL,
UTCL04_RESPONSE_1,
UTCL04_RESPONSE_2,
UTCL04_RESPONSE_3,
UTCL04_RESPONSE_4
--,OTCL04_D_CCATID3

from(
select
base.OTCL04_D_PARTNER as UTCL04_D_PARTNER,
bpar.DDBPAR_NAZEV as UTCL04_BPAR_NAZEV,
base.OTCL04_D_DCLCREA as UTCL04_DATE_VALID,
base.OTCL04_D_TCLCREA as UTCL04_TIME_VALID,
base.OTCL04_D_ID_OBJ as UTCL04_D_ID_OBJ,
categ.xCATID1 as UTCL04_D_XCATID1,
categ.xCATID2 as UTCL04_D_XCATID2,
categ.xCATID3 as UTCL04_D_XCATID3,
base.OTCL04_D_CCATID3,
categ.catg_type ,
base.OTCL04_D_KANAL as UTCL04_D_KANAL,
base.OTCL04_D_ZAL_U as UTCL04_D_ZALOZIL,
base.OTCL04_D_ZME_U as UTCL04_D_RESITEL,
base.RESPONSE_1 as UTCL04_RESPONSE_1,
base.RESPONSE_2 as UTCL04_RESPONSE_2,
base.RESPONSE_3 as UTCL04_RESPONSE_3,
base.RESPONSE_4 as UTCL04_RESPONSE_4,
userKPJM,
 row_number()  OVER (ORDER BY base.OTCL04_D_PARTNER ) as UTCL04_poradi
from 
GT_FIN_QUEST base
INNER JOIN 
(select DDBPAR_D_PARTNER, DDBPAR_NAZEV from OWNBT_DWH.DSD_BPAR WHERE DDBPAR_CURRENT_FLAG = 1 ) bpar
ON (base.OTCL04_D_PARTNER  = bpar.DDBPAR_D_PARTNER)
LEFT OUTER JOIN 
GT_CATEG categ
ON (base.OTCL04_D_ID_OBJ = categ.OTCL04_D_ID_OBJ)
    left join OWNBT_STG.sut_cx01_zzz_sub_gdpr_01_mv GDPR    on base.OTCL04_D_PARTNER  = GDPR.ddbpar_d_partner

where 1 = 1
-- nema GDPR omezeni
  and GDPR.ddbpar_d_partner is null
--  and OTCL04_D_CCATID3 = 'V063'
  )

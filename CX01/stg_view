temp_nasledky_cx as

(
select    
-- následky
    AC.OTAC01_D_ID_OBJ   ID_NO,
    AC.OTAC01_D_PARTNER  OP, 
    AC.OTAC01_D_CCATID3  KATEGORIE_3,
    
    AC.OTAC01_D_USER2    ZALOZIL_NO_KPJM,
    AC.OTAC01_D_BP_USE2  ZALOZIL_NO_BP,
    
    OJ.OTOJ01_D_ORGET6  ZALOZIL_NO_SKUPINA,
    OJ.OTOJ01_D_ORGET5  ZALOZIL_NO_ODDELENI,
    OJ.OTOJ01_D_ORGET4  ZALOZIL_NO_ODBOR,
    
    trunc(AC.OTAC01_D_ERDAT)   DAT_ZALOZENI_NO,
    Trunc(AC.OTAC01_D_DATUZA)  DAT_UZAVRENI_NO,

-- z IPOD
    nvl(IPOD.OTIPOD_D_EXT_UI, 'N/A')  EAN_EIC,
    AC.*

from
    OWNBT_ODS.ODT_AC01 AC -- následky

left join
    OWNBT_ODS.ODT_BP13 BP
    on  BP.OTBP13_CURRENT_FLAG = 1   
    and AC.OTAC01_D_USER2 = BP.OTBP13_D_USER
    and AC.OTAC01_D_ERDAT = BP.OTBP13_D_DATEORG

left join
    OWNBT_ODS.ODT_OJ01 OJ
    on  OJ.OTOJ01_CURRENT_FLAG = 1   

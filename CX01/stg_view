inner join
    ownbt_ods.odt_ac01 
on odt_ac02.otac02_d_activit= odt_ac01.otac01_d_activit
    and OTAC01_D_ERDAT > add_months(sysdate,-3)  and
        OTAC01_CURRENT_FLAG = 1 AND
        OTAC01_D_DIRECT = '0' AND
        otac01_d_emailos <> 'N/A' 

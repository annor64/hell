        INNER JOIN
        ownbt_dwh.dst_akvi akvi
        ON (akvi.dtakvi_effective_date = dsd.dddate_id)
        where akvi.dtakvi_stat_fin IN ('V_PROCESU')
        and dsd.dddate_id between akvi.dtakvi_valid_From and akvi.dtakvi_valid_to
        group by
        akvi.dtakvi_d_partner
),

IN_OTH_LEAD as (
        select
        ZAJEMCE_FINAL
        from
        (
            select
            CASE WHEN DDLEAA_PRVNI_ZAJEMCE <> DDLEAA_LE03_ZAJEMCE AND DDLEAA_LE01_D_LEAD_START NOT BETWEEN DDLEAA_LE03_ZAJEMCE_DATEFROM and DDLEAA_LE03_ZAJEMCE_DATETO
            THEN DDLEAA_LE03_ZAJEMCE ELSE DDLEAA_PRVNI_ZAJEMCE END as ZAJEMCE_FINAL,
            le.ddleaa_posledni_usst_semafor,
            trunc(le.DDLEAA_POSLEDNI_BUSINESS_STATUS_DATUM) as DDLEAA_POSLEDNI_BUSINESS_STATUS_DATUM,
            max(trunc(le.DDLEAA_POSLEDNI_BUSINESS_STATUS_DATUM)) over (partition by
            CASE WHEN DDLEAA_PRVNI_ZAJEMCE <> DDLEAA_LE03_ZAJEMCE AND DDLEAA_LE01_D_LEAD_START NOT BETWEEN DDLEAA_LE03_ZAJEMCE_DATEFROM and DDLEAA_LE03_ZAJEMCE_DATETO
            THEN DDLEAA_LE03_ZAJEMCE ELSE DDLEAA_PRVNI_ZAJEMCE END
            ) as max_DDLEAA_POSLEDNI_BUSINESS_STATUS_DATUM
            from
            OWNBT_DWH.DLD_LEAD_ACTL le
                where ddleaa_prvni_zajemce <> 'N/A' and ddleaa_le03_zajemce <> 'N/A'
        ) x
        where DDLEAA_POSLEDNI_BUSINESS_STATUS_DATUM = max_DDLEAA_POSLEDNI_BUSINESS_STATUS_DATUM
        and max_DDLEAA_POSLEDNI_BUSINESS_STATUS_DATUM > sysdate - 90
        GROUP BY ZAJEMCE_FINAL
        HAVING
        MAX(CASE WHEN DDLEAA_POSLEDNI_USST_SEMAFOR in ('JIZ_MA') THEN 1 ELSE 0 END) +
        MAX(CASE WHEN DDLEAA_POSLEDNI_USST_SEMAFOR in ('USPECH') THEN 1 ELSE 0 END) +
        MAX(CASE WHEN DDLEAA_POSLEDNI_USST_SEMAFOR in ('ZPRACOVAVA_SE') THEN 1 ELSE 0 END) +

GT_USER AS (
    select DDUSER_KPJM, DDUSER_DATEFROM, DDUSER_DATETO,DDUSER_VALID_FROM,DDUSER_VALID_TO from
    ownbt_dwh.dld_user zal
    where dduser_tym in ('skupina Speciální služby A 1','skupina Speciální služby A 2','skupina Speciální služby A 3',
                         'skupina Speciální služby A 4','skupina Speciální služby A 5','skupina Speciální služby A 6',

  CREATE OR REPLACE FORCE EDITIONABLE VIEW "OWNBT_STG"."SUT_CX01_LEOS_01_INIT_V" ("UTLEOS_ID", "UTLEOS_D_ACTIVIT", "UTLEOS_D_ID_OBJ", "UTLEOS_D_ERDAT", "UTLEOS_D_DATUZA", "UTLEOS_D_CCATID1", "UTLEOS_D_CCATID2", "UTLEOS_D_PARTNER", "UTLEOS_D_ZALOZIL_D_USER", "UTLEOS_D_RESITEL_D_USER", "UTLEOS_D_CRM_UZS", "UTLEOS_ID_KPI", "UTLEOS_DDBPAR_NAZEV", "UTLEOS_ROZHODNE_DATUM", "UTLEOS_D_CCATID3", "UTLEOS_D_OSL_DOP") AS 
  select utac01_id, utac01_d_activit, utac01_d_id_obj, utac01_d_erdat, utac01_d_datuza,  utac01_d_ccatid1, utac01_d_ccatid2, utac01_d_partner, utac01_d_zalozil_d_user, utac01_d_resitel_d_user, utac01_d_crm_uzs, utac01_id_kpi,  utac01_ddbpar_nazev, utac01_rozhodne_datum, utac01_d_ccatid3, utac01_d_osl_dop
--FVE a TCP Podpis smlouvy
from
(
WITH OTZ AS (
select * from
    (
        select
        rela.otobchpvaz_id_obchodni_pripad  as otz_otobchp_obchodni_pripad_id ,
        akti.otakt_zastupce_vlastnik_kpjm as OTZ_KPJM,
        row_number() over (partition by rela.otobchpvaz_id_obchodni_pripad  order by akti.otakt_pocatek desc) as rnk
        from
            leo_ods.odt_obch_pri_vazba_aktivita rela
        INNER JOIN
            (select * from leo_ods.odt_aktivita_v where otakt_objekt IN ('aktivita typu FVE Návštěva','aktivita typu TČ Návštěva','aktivita typu AC Návštěva','aktivita typu LIGHT Návštěva') and otakt_stav_TXTF in('Uskutečněná','Uskutečněná - automaticky uzavřeno') ) akti
                ON akti.otakt_aktivita_id = rela.otobchpvaz_id_aktivita -- toto je tedy vazba na obchodn ho z stupce (OTZ)
        where rela.otobchpvaz_current_Flag = 1
    ) x where x.rnk = 1
),
finalni_nabidka as (
select 
        smlouva_id,
        finalni_nabidka_odeslana_Nastaveno
    from
        ( 
        select otobchpls_obchodni_pripad_id     as smlouva_id
             , trunc(OTOBCHPLS_ZMENA_KDY)          as finalni_nabidka_odeslana_Nastaveno 
             , row_number() over (partition by otobchpls_obchodni_pripad_id order by trunc(OTOBCHPLS_ZMENA_KDY) desc) rn -- uskutocnena/ostatni
        from leo_ods.odt_obch_pri_log_stavu              
        where 1 = 1
        and otobchpls_stav_id   in ( 1167,144,1183, 1198)       -- Finaln  nabidka odeslana
        and otobchpls_current_flag=1
  )
 where rn =1
 ),
smlouva_podepsana as (

select smlouva_id
     , smlouva_podepsana_datum
     , smlouva_podepsana_nastaveno
from
(
select otobchpls_obchodni_pripad_id     as smlouva_id
     , to_date(otobchpd_hodnota,'DD.MM.YYYY')                  as smlouva_podepsana_datum
     , trunc(OTOBCHPLS_ZMENA_KDY)                              as smlouva_podepsana_nastaveno
     , row_number() over (partition by otobchpls_obchodni_pripad_id order by otobchpls_zmena_kdy asc, otobchpls_predchozi_stav_id) rn -- uskutocnena/ostatni
from leo_ods.odt_obch_pri_log_stavu                        

     join leo_ods.odt_obch_pri_detail     detail              on otobchpd_id            = otobchpls_obchodni_pripad_id
                                                              and otobchpd_deskr_id    in (318,66,732) 
                                                              and otobchpd_current_flag = 1
where 1 = 1
     and otobchpls_stav_id   in(147,1170,1186,1198)        -- smouva podepsana
     and otobchpls_current_flag=1
)
where rn = 1
)
--FVE a TCP Podpis smlouvy
select distinct

  to_char(otobchp_typ_id) || '10000' ||to_char(otobchp_obchodni_pripad_id)             as utac01_id  
, to_char(otobchp_typ_id) || '10000' ||to_char(otobchp_obchodni_pripad_id)             as utac01_d_activit
, to_char(otobchp_obchodni_pripad_id)                                                                              as utac01_d_id_obj
, to_char(smlouva_podepsana_datum,'yyyymmdd')                                                                      as utac01_d_erdat
, to_char(finalni_nabidka_odeslana_Nastaveno,'yyyymmdd')                                                           as utac01_d_datuza
, case when otobchp_typ_id = 10 then 'FVE1' when otobchp_typ_id = 21 then 'TCP1' when otobchp_typ_id = 23 then 'TCP2' when otobchp_typ_id = 24 then 'FVE2'  end as utac01_d_ccatid1
, case when otobchp_typ_id in(10,24) then 'FVE2' else 'TCP2' end                                                   as utac01_d_ccatid2
, otkonos_zakaznicke_cislo                                                                                         as utac01_d_partner
, xotz.OTZ_KPJM                                                                                                    as utac01_d_zalozil_d_user
, obchpripad.OTOBCHP_PARTNER_PRO_NAVSTEVU_TXTF                                                                     as utac01_d_resitel_d_user
, NULL                                                                                                             as utac01_d_crm_uzs 
, 'I09'                                                                                                            as utac01_id_kpi
, otkonos_jmeno||' '||otkonos_prijmeni                                                                             as utac01_ddbpar_nazev
, smlouva_podepsana_nastaveno +2/* Pridavame dva dny at to pak je v D3 celkem5 dni */                              as utac01_rozhodne_datum
, '0001'                                                                                                           as utac01_d_ccatid3
, otkonos_osloveni                                                                                                 as utac01_d_osl_dop


from leo_ods.odt_obch_pri_v               obchpripad

     join otz xotz                                            ON (xotz.otz_otobchp_obchodni_pripad_id = obchpripad.otobchp_obchodni_pripad_id)

     left join finalni_nabidka                          on otobchp_obchodni_pripad_id = finalni_nabidka.smlouva_id

     join smlouva_podepsana                          on otobchp_obchodni_pripad_id = smlouva_podepsana.smlouva_id


     join leo_ods.odt_zastupce_vlastnik      ko               on  obchpripad.otobchp_kontaktni_osoba_id = ko.oczv_zastupce_vlastnik_id
                                                              and ko.oczv_current_flag=1

     join leo_ods.odt_kontaktni_osoba        osboa            on oczv_id_osoba = otkonos_id_osoba
                                                              and otkonos_current_flag = 1
                                                              and not otkonos_id_osoba = 0
where 1=1
and otobchp_typ_id                in(10,21,23,24)        --  10 FVE / 21 TC    
and not upper(otkonos_jmeno||' '||otkonos_prijmeni ) like '%TEST%'
)
union all



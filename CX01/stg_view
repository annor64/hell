),

-- tohle cele je strasna prasarna kde vubec nechapu ty vsechny subselecty, ale radeji do toho hrabat nebudu.
GT_BASE AS (
select a.* 
from 
(
    select 
    DTAKVI_ID_BALICKU, 
    DTAKVI_D_PARTNER,
    X_D_CRM_LEA,

    MAX(case when nvl(DTAKVI_OTPD01_D_ZALOZIL_KPJM,'N/A') <> 'N/A' THEN DTAKVI_OTPD01_D_ZALOZIL_KPJM else null end ) as DTAKVI_OTPD01_D_ZALOZIL_KPJM,
    MAX(case when nvl(dtakvi_Typ_fin_Business,'N/A') <> 'N/A' then dtakvi_Typ_fin_Business else null end) as dtakvi_Typ_fin_Business,
    MAX(case when DTAKVI_DATUM_P01 is not null then DTAKVI_DATUM_P01 else null end ) as DTAKVI_DATUM_P01,
    MAX(case when DTAKVI_DATUM_P02 is not null then DTAKVI_DATUM_P02 else null end ) as DTAKVI_DATUM_P02,
    MAX(case when NVL(DTAKVI_B_PRVNI_KANAL,'NERELEVANTNI')  <>  'NERELEVANTNI' THEN DTAKVI_B_PRVNI_KANAL  else null end) as DT_AKVI_AKVIZICNI_KANAL,
    MAX(        
        CASE 
        WHEN  DTAKVI_STAT_FIN = 'V_PROCESU' then 1   
        WHEN  DTAKVI_STAT_FIN = 'USPESNA' then 4
        WHEN  DTAKVI_STAT_FIN = 'NEUSPESNA' then 3
        WHEN  DTAKVI_STAT_FIN = 'STORNO' then 2
        END
    ) as MAX_PRIO_PROCES -- kvůli zjištění, zda maximální dosažený status pro ID_BALICKU je V_PROCESU
    from 
    (
        select 
        vazb.*, akvi.*
        from 
        GT_VAZB vazb
        INNER JOIN 
        ownbt_dwh.dst_akvi akvi
        ON (vazb.akvi_id_balicku = akvi.DTAKVI_ID_BALICKU
        -- 2021.08.02 stalo se ze nekdo udelal smlouvu i nekomu jinemu nez se melo volat, a tak nakonec byly dva zaznamy pro DDLEAA_ID, coz nema nastat
        and vazb.akvi_partner = akvi.DTAKVI_D_PARTNER)
    where      akvi.dtakvi_effective_Date = (select DDDATE_ID from OWNBT_DWH.DSD_DATE where DDDATE_CURRENT_FLAG = 1)
    and akvi.dtakvi_ind_prvni_p02 = 1 and akvi.dtakvi_ind_p08 = 0 -- existuje P02 , ale ještě není P08 (smlouva)
    ) akvi

    group by 
    DTAKVI_ID_BALICKU, 
    DTAKVI_D_PARTNER,
    X_D_CRM_LEA
) a 
WHERE 
LOWER(DT_AKVI_AKVIZICNI_KANAL)  in( 'www.cez.cz', 'call centrum') -- vždy pouze call centrum
and MAX_PRIO_PROCES = 1 -- granulatita balíčku / PFI -- vždy pouze stav V_PROCESU v rámci balíčku.

), 


GT_PREOUT AS (
select * from 
(
    select 
    DTAKVI_D_PARTNER,
    DDLEAA_ID, 
    DTAKVI_DATUM_P01, 
    DTAKVI_DATUM_P02, 
    DTAKVI_TYP_FIN_BUSINESS, 
    DTAKVI_OTPD01_D_ZALOZIL_KPJM ,
    X_D_CRM_LEA,
    lea.DDLEAA_D_ID_OBJ ,
    case when not res2.DDUSER_KPJM is null then lea.DDLEAA_POSLEDNI_BUSINESS_KPJM  else lea.DDLEAA_LE03_ODPOV end as DDLEAA_LE01_D_ZMENIL,
    DDLEAA_LE01_D_PRODUKT, 
    odt_le01.otle01_tel_number, 
    DDLEAA_POSLEDNI_USST,

    row_number() over (partition by DTAKVI_D_PARTNER order by DTAKVI_DATUM_P02 desc) as rnk

    from 
    GT_BASE bas
    INNER JOIN 
    ownbt_dwh.dld_lead_actl lea -- přímá vazba na akviziční lead. Je to hlavni na analyzi nad leady dulezite od frantiska kmotrika
    ON (lea.DDLEAA_D_CRM_LEA = bas.X_D_CRM_LEA)


    INNER JOIN 
    ownbt_ods.odt_le01 
    ON (bas.X_D_CRM_LEA = odt_le01.OTLE01_D_CRM_LEA and odt_le01.OTLE01_CURRENT_FLAG = 1)
    INNER JOIN 
    GT_USER zal
    ON (zal.DDUSER_KPJM = bas.DTAKVI_OTPD01_D_ZALOZIL_KPJM AND trunc(bas.DTAKVI_DATUM_P02) BETWEEN trunc(zal.DDUSER_DATEFROM) and trunc(zal.DDUSER_DATETO) AND 
    to_number(to_char(bas.DTAKVI_DATUM_P02,'YYYYMMDD')) BETWEEN zal.DDUSER_VALID_FROM and zal.DDUSER_VALID_TO
    )

    Left outer JOIN 
    GT_USER res2
    ON (res2.DDUSER_KPJM = lea.DDLEAA_POSLEDNI_BUSINESS_KPJM AND trunc(bas.DTAKVI_DATUM_P02) BETWEEN trunc(res2.DDUSER_DATEFROM) and trunc(res2.DDUSER_DATETO) AND 
    to_number(to_char(bas.DTAKVI_DATUM_P02,'YYYYMMDD')) BETWEEN res2.DDUSER_VALID_FROM and res2.DDUSER_VALID_TO 
    )
    Left outer JOIN 
    GT_USER res3
    ON (res3.DDUSER_KPJM = lea.DDLEAA_LE03_ODPOV AND trunc(bas.DTAKVI_DATUM_P02) BETWEEN trunc(res3.DDUSER_DATEFROM) and trunc(res3.DDUSER_DATETO) AND 
    to_number(to_char(bas.DTAKVI_DATUM_P02,'YYYYMMDD')) BETWEEN res3.DDUSER_VALID_FROM and res3.DDUSER_VALID_TO 
    )

    where  
    DDLEAA_POSLEDNI_USST_SEMAFOR IN ('USPECH') --úspěný lead - má zájem, nabídka vyřešena 
    AND DTAKVI_DATUM_P01 >= add_months(trunc(sysdate),-6) -- první datum P01 nesmí být starší než 180 dnů
    and DTAKVI_TYP_FIN_BUSINESS IN ('NOVY_NEBO_OBNOVENY_ODBER', 'NOVY_ODBER', 'OBNOVENY_ODBER', 'PREPIS_BEZ_ZD', 'PREPIS_SE_ZD', 'STANDARDNI_ZD') 
    -- výčet. nesmí tam být návaznost na neoprávněný odběr nebo nějaká heuristika 
    and (not res2.DDUSER_KPJM is null or not res3.DDUSER_KPJM is null)
    and 
        (
        -- bereme but callcentrum nebo kampan setrim z www.cez.cz
            LOWER(DT_AKVI_AKVIZICNI_KANAL) in( 'call centrum') -- vždy pouze call centrum
        or
        -- 2021.11.22 zmena po diskuzi s Frantiskem Kmotrikem
            --cmp.kampan ='Šetřím.cz'
        lea.ddleaa_d_crm_lea_txtmd ='Šetřím.cz'
        )
) x
where rnk = 1  
)


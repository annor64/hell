  CREATE OR REPLACE FORCE EDITIONABLE VIEW "OWNBT_STG"."SUT_CX01_TI01_01_MAIL_INIT_V" ("UTTI01_XCCPRO_KEY", "UTTI01_EXPORT_FILENAME", "UTTI01_EFFECTIVE_DATE", "UTTI01_ID", "UTTI01_D_ACTIVIT", "UTTI01_D_ID_OBJ", "UTTI01_D_ERDAT", "UTTI01_D_DATUZA", "UTTI01_TIMEZAL", "UTTI01_D_CCATID1", "UTTI01_D_CCATID2", "UTTI01_D_DIRECT", "UTTI01_D_KANAL", "UTTI01_D_ELE_FL", "UTTI01_D_PARNTER", "UTTI01_D_AD02_TEL", "UTTI01_D_PLY_FL", "UTTI01_D_TELNVO", "UTTI01_EMAIL", "UTTI01_ADRESA_ULICE", "UTTI01_ADRESA_CP", "UTTI01_ADRESA_CO", "UTTI01_ADRESA_MISTO", "UTTI01_ADRESA_MISTNI_CAST", "UTTI01_ADRESA_PSC", "UTTI01_D_ZALOZIL_D_USER", "UTTI01_D_RESITEL_D_USER", "UTTI01_POCET_RESITELU", "UTTI01_D_CRM_UZS", "UTTI01_DDBPAR_NAZEV", "UTTI01_BONITA", "UTTI01_SEGMENTACE", "UTTI01_POCET_MS", "UTTI01_ODHAD_SPOTREBY", "UTTI01_HODNOTA_ZAKAZNIKA", "UTTI01_PRACOVISTE", "UTTI01_ID_KPI", "UTTI01_VLASTNIK_DAT", "UTTI01_ROZHODNE_DATUM", "UTTI01_D_CCATID3", "UTTI01_D_MOB_FL", "UTTI01_D_OSL_DOP", "UTTI01_POHLAVI", "UTTI01_PORADI", "UTTI01_D_PROCTYP", "UTTI01_D_OTH_FL", "UTTI01_VARIANTA") AS 
  WITH xfc as
 (
 select xccpro_key, xccpro_filename_templ, xccpro_filename_key, xccpro_filename_date,XCCPRO_DATE_OFFSET_FROM,XCCPRO_DATE_OFFSET_TO,XCCPRO_PROCESS_DATE
 from bisupport.xfc_cpro      
        where xccpro_key = 'CAWI_CX01_TI01_D1_MAIL'        
           and xccpro_current_flag = 1
),

otzd as (
select 
     otti01_d_crm_ti,
     otzd01_d_proctyp
     from (
SELECT
     ti01.otti01_d_crm_ti,
     zd01.otzd01_d_proctyp,
     row_number() over(partition by ti01.otti01_d_crm_ti order by DBMS_RANDOM.RANDOM asc) as RN
 FROM
     ownbt_ods.odt_ti01 ti01
     INNER JOIN ownbt_ods.odt_ti02 ti02 ON ti01.otti01_d_crm_ti = ti02.otti02_d_crm_ti
                                           AND ti02.otti02_current_flag = '1'
                                           AND ti02.otti02_d_proctyf = 'ZCDC'
     INNER JOIN ownbt_ods.odt_zd01_v zd01 ON ti02.otti02_d_id_objr = zd01.otzd01_d_id_obj
                                            and zd01.otzd01_current_flag = '1'

 WHERE
     ti01.otti01_current_flag = '1'
     ) where rn =1
),

GT_BASE AS  (

        select 
            xccpro_key as utti01_xccpro_key,
            xccpro_filename_templ||'_'||replace(xccpro_filename_key,'YYYYMMDD',to_char(xccpro_filename_date,'YYYYMMDD')) as utti01_export_filename, 
            to_char(xccpro_process_date,'YYYYMMDD') as utti01_effective_date,
            otti01_d_id_obj as UTTI01_ID,
            ac01.otac01_d_activit as utti01_d_activit,
            ac01.otac01_d_id_obj as utti01_d_id_obj,
            to_char(otti01_d_erdat,'YYYYMMDD') as utti01_d_erdat,
            to_char(otti01_d_aedat,'YYYYMMDD') as utti01_d_datuza,
            otti01_d_tcatid1 as utti01_d_ccatid1,
            otti01_d_tcatid2 as utti01_d_ccatid2,        
            otti01_d_direct as utti01_d_direct,
            CASE WHEN otti01_d_kanal IN ('28') THEN 28 else -1 end as utti01_d_kanal,
            CASE WHEN otti01_d_druhslt = 'ELE' THEN 'X' else  null end as utti01_d_ele_fl,
            otti01_d_partner as utti01_d_parnter,
            CASE WHEN otti01_d_druhslt = 'GAS' THEN 'X' else  null end as utti01_d_ply_fl,
            email.EMAIL_HLAVNI as UTTI01_EMAIL,
           

            otti01_D_zalozil_KPJM as utti01_d_zalozil_d_user,
            otti01_d_odpov_kpjm as utti01_d_resitel_d_user,

            otti01_d_tcatst as utti01_d_crm_uzs,
            bpar.DDBPAR_NAZEV as utti01_ddbpar_nazev,

            to_char(otti01_d_aedat,'YYYYMMDD') as UTTI01_ROZHODNE_DATUM,
            otti01_d_tcatid3 as UTTI01_D_CCATID3,        
            CASE WHEN otti01_d_druhslt = 'MOB' THEN 'X' else  null end as UTTI01_D_MOB_FL,
            decode(bpar.ddbpar_d_osl_dop ,'N/A',null,bpar.ddbpar_d_osl_dop ) as UTTI01_D_OSL_DOP,
            decode(bpar.ddbpar_pohlavi,'M','1','Z','2','N',null,ddbpar_pohlavi)as UTTI01_POHLAVI,
            otzd01_d_proctyp                               as utti01_d_proctyp,
            decode(ti01.otti01_d_druhslt,'MOB',NULL,'GAS',NULL,'ELE',NULL,'N/A',null,'X')   as utti01_d_oth_fl -- vsechny co se nepouzivaji se nastavi na X
            from 
            (
                select * 
                from 
                OWNBT_ODS.odt_ti01 ti01 
                CROSS JOIN
                xfc  xfc 
                where otti01_d_erdat > sysdate - 90 
                AND trunc(otti01_d_aedat) = trunc(xfc.xccpro_process_date + xfc.xccpro_date_offset_from)
                and ti01.otti01_current_flag = 1
                and otti01_d_proctyp = 'ZTIC'    
                and ti01.otti01_d_kanal IN ('28') -- pouze kanál převzetí = email

            ) ti01
            INNER JOIN 
            OWNBT_ODS.odt_ti02 ti02
                ON 
                    ti01.otti01_d_crm_ti = ti02.otti02_d_crm_ti 
                    and ti02.otti02_current_flag = 1 
            INNER JOIN 
                OWNBT_ODS.odt_ac01 ac01 
                    ON 
                        ac01.otac01_d_activit = ti02.otti02_d_activit 
                        and ac01.otac01_current_flag = 1 
                        and ac01.otac01_d_erdat > trunc(sysdate) - 90 
            INNER JOIN
                OWNBT_DWH.DSD_BPAR bpar
                    ON bpar.DDBPAR_D_PARTNER = ti01.OTTI01_D_PARTNER 
                        and bpar.DDBPAR_CURRENT_FLAG = 1


        when substr(otac01_d_ccatid3,1,7)  = 'REK_CSV'  then 'C0'|| Substr(otac01_d_ccatid3,-2)
        when substr(otac01_d_ccatid3,1,7)  = 'REK_FVE'  then 'F0'|| Substr(otac01_d_ccatid3,-2)
        when substr(otac01_d_ccatid3,1,11) = 'REK_OSTATNI'  then 'O0'|| Substr(otac01_d_ccatid3,-2)
        when substr(otac01_d_ccatid3,1,13) = 'REK_SERV_PROD'  then 'S0'|| Substr(otac01_d_ccatid3,-2)
        when substr(otac01_d_ccatid3,1,10) = 'REK_POJIST'  then 'J0'|| Substr(otac01_d_ccatid3,-2)
        when substr(otac01_d_ccatid3,1,8)  = 'REK_TECH'  then 'T0'|| Substr(otac01_d_ccatid3,-2)

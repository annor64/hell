  CREATE OR REPLACE FORCE EDITIONABLE VIEW "OWNBT_STG"."SUT_CX01_TI01_01_SOL_INIT_V" ("UTTI01_ID", "UTTI01_D_ACTIVIT", "UTTI01_D_ID_OBJ", "UTTI01_D_ERDAT", "UTTI01_D_DATUZA", "UTTI01_D_CCATID1", "UTTI01_D_CCATID2", "UTTI01_D_DIRECT", "UTTI01_D_KANAL", "UTTI01_D_ELE_FL", "UTTI01_D_PARTNER", "UTTI01_AD02_TEL", "UTTI01_D_PLY_FL", "UTTI01_EMAIL", "UTTI01_D_ZALOZIL_D_USER", "UTTI01_D_RESITEL_D_USER", "UTTI01_D_CRM_UZS", "UTTI01_DDBPAR_NAZEV", "UTTI01_VLASTNIK_DAT", "UTTI01_ROZHODNE_DATUM", "UTTI01_D_CCATID3", "UTTI01_D_MOB_FL", "UTTI01_D_OSL_DOP", "UTTI01_POHLAVI", "UTTI01_VARIANTA", "UTTI01_D_PROCTYP", "UTTI01_D_OTH_FL") AS 
  with 
  ti01 as (
    select /*+ full(ti01)*/ ti01.*, case when otsm01_d_prod=  '001A4A1A09B61ED789A020B9B73E068C'  then 'EPSA' else 'EPSB' end as utti01_d_proctyp
    from  ownbt_ods.odt_ti01 ti01
       join  ownbt_ods.odt_ti02  on
            odt_ti02.otti02_d_crm_ti = ti01.otti01_d_crm_ti
            and OTTI02_D_PROCTYP = 'ZTIC' and OTTI02_D_PROCTYF = 'ZQR1' and otti02_current_flag = 1
         join OWNBT_ODS.ODT_SM01 
                on otti02_d_crm_nab = otsm01_d_crm_nab  
                and otsm01_current_flag = 1 
                and otsm01_d_prod  in('001A4A1A09B61ED789A020B9B73E068C','001A4A1A09B61EEDBFF38045C86D586D')
    where 1=1
       and ti01.otti01_current_flag = 1  
--       and ti01.otti01_d_druhslt in ('MOB','ELE','GAS')  -- mobil, ele, plyn
       and ti01.otti01_d_proctyp in ('ZTIC') -- typ operace ZTIC
       and ti01.otti01_d_kanal in ('01','03','07','33','04','34','28')
       and ti01.otti01_d_direct in ('3')
       and ti01.otti01_d_tcatid1||'-'||ti01.otti01_d_tcatid2||'-'||ti01.otti01_d_tcatid3||'-'||ti01.otti01_d_tcatst
                         in (
                              '040000-040001-040101-CP_DONE'           -- zmena produktu
                            , '040000-040001-040102-PP_DONE'           -- prodlouzeni produktu
                            ) 
       and sysdate - ti01.otti01_d_datuza2 < 10
),

sut_cx01_zzz_sub_act_sml_01_mv as 

(
 select distinct dfsmoa_isml_d_partner   from ownbt_dwh.dsf_smom_actl
                                                   where  trunc (sysdate) between dfsmoa_datefrom and dfsmoa_dateto
                                                   and dfsmoa_ind_poh = 'A'  
                                                   and dfsmoa_main_segment <> 'N/A'
)


select 
 /*+  FULL(ti01) FULL(zd01) full(act_sml) FULL(email) FULL(tel) FULL(GDPR) */
 /*+  USE_HASH( ti01, zd01,act_sml,dsd_bpar, email, tel, GDPR) */
       ti01.otti01_id                                 as utti01_id       
      ,ti01.otti01_d_crm_ti                           as utti01_d_activit
      ,ti01.otti01_d_id_obj                           as utti01_d_id_obj
      ,ti01.otti01_d_erdat                            as utti01_d_erdat 
      ,ti01.otti01_d_datuza2                          as utti01_d_datuza 
      ,ti01.otti01_d_tcatid1                          as utti01_d_ccatid1 
      ,ti01.otti01_d_tcatid2                          as utti01_d_ccatid2
      ,ti01.otti01_d_direct                           as utti01_d_direct  
      ,ti01.otti01_d_kanal                            as utti01_d_kanal
      ,decode(ti01.otti01_d_druhslt,'ELE','X',null)   as utti01_d_ele_fl
      ,ti01.otti01_d_partner                          as utti01_d_partner
      ,tel.telefon_hlavni                             as utti01_ad02_tel
      ,decode(ti01.otti01_d_druhslt,'GAS','X',null)   as utti01_d_ply_fl
      ,email.email_hlavni                             as utti01_email
      ,ti01.otti01_d_zalozil_kpjm                     as utti01_d_zalozil_d_user
      ,ti01.otti01_d_odpov_kpjm                       as utti01_d_resitel_d_user
      ,ti01.OTTI01_D_TCATST                           as utti01_d_crm_uzs
      ,ddbpar_nazev                                   as utti01_ddbpar_nazev
      ,cast (1 as NUMBER)                             as utti01_vlastnik_dat    
      ,ti01.otti01_d_datuza2                          as utti01_rozhodne_datum 
      ,ti01.otti01_d_tcatid3                          as utti01_d_ccatid3  
      ,decode(ti01.otti01_d_druhslt,'MOB','X',null)   as utti01_d_mob_fl
      ,ddbpar_d_osl_dop                           as utti01_d_osl_dop
      ,decode(ddbpar_pohlavi,'M','1','Z','2','N',null,ddbpar_pohlavi) as utti01_pohlavi
      ,case when ti01.otti01_d_erdat - ti01.otti01_d_datuza2  <=21 then 1 else 2 end as utti01_varianta
      ,utti01_d_proctyp                               as utti01_d_proctyp
      ,decode(ti01.otti01_d_druhslt,'MOB',NULL,'GAS',NULL,'ELE',NULL,'N/A',null,'X')   as utti01_d_oth_fl

from ti01 ti01

     join ownbt_dwh.dsd_bpar                on ti01.otti01_d_partner      = ddbpar_d_partner 
                                                  and ddbpar_current_flag  =1

    join sut_cx01_zzz_sub_act_sml_01_mv act_sml          on ti01.otti01_d_partner = act_sml.dfsmoa_isml_d_partner -- existuje platna smlouva

    left join OWNBT_STG.sut_cx01_zzz_sub_email_01_mv email  on ti01.otti01_d_partner = email.Partner_email_hlavni

    left join OWNBT_STG.sut_cx01_zzz_sub_tel_01_mv tel    on ti01.otti01_d_partner = tel.Partner_telefon_hlavni

    left join OWNBT_STG.sut_cx01_zzz_sub_gdpr_01_mv GDPR    on ti01.otti01_d_partner = GDPR.ddbpar_d_partner


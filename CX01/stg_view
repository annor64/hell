  WITH 
GT_BASE AS (
select a.* 
from 
(
    select 
    DTAKVI_ID_BALICKU, 
    DTAKVI_D_PARTNER,
    DTAKVI_KOMODITA,
    DTAKVI_D_ID_OBJ,
    MAX(case when nvl(DTAKVI_OTPD01_D_ZALOZIL_KPJM,'N/A') <> 'N/A' THEN DTAKVI_OTPD01_D_ZALOZIL_KPJM else null end ) as DTAKVI_OTPD01_D_ZALOZIL_KPJM,
    MAX(case when nvl(DTAKVI_OTNA01_D_ZMENIL_KPJM,'N/A') <> 'N/A' THEN DTAKVI_OTNA01_D_ZMENIL_KPJM else null end ) as DTAKVI_OTNA01_D_ZMENIL_KPJM,
    MAX(case when nvl(dtakvi_Typ_fin_Business,'N/A') <> 'N/A' then dtakvi_Typ_fin_Business else null end) as dtakvi_Typ_fin_Business,
    MAX(case when DTAKVI_DATUM_P01 is not null then DTAKVI_DATUM_P01 else null end ) as DTAKVI_DATUM_P01,
    MAX(case when DTAKVI_DATUM_P02 is not null then DTAKVI_DATUM_P02 else null end ) as DTAKVI_DATUM_P02,
    MAX(        
        CASE 
        WHEN  DTAKVI_STAT_FIN = 'V_PROCESU' then 1   
        WHEN  DTAKVI_STAT_FIN = 'USPESNA' then 4
        WHEN  DTAKVI_STAT_FIN = 'NEUSPESNA' then 3
        WHEN  DTAKVI_STAT_FIN = 'STORNO' then 2
        END
    ) as MAX_PRIO_PROCES -- kvůli zjištění, zda maximální dosažený status pro ID_BALICKU je V_PROCESU
    from 
    (
        select 
        akvi.*, max(dtakvi_valid_from) over (partition by DTAKVI_ID_BALICKU) as max_dtakvi_valid_From
        from
        ownbt_dwh.dst_akvi akvi
    where 1=1  --max_dtakvi_valid_From = dtakvi_valid_From -- poslední záznam na ID balíčku
    and akvi.dtakvi_ind_prvni_p02 = 1 and akvi.dtakvi_ind_p08 = 0 -- existuje P02 , ale ještě není P08 (smlouva)
    and akvi.dtakvi_effective_Date = (select DDDATE_ID from OWNBT_DWH.DSD_DATE where DDDATE_CURRENT_FLAG = 1)
    and akvi.DTAKVI_VALID_TO > TO_NUMBER(TO_CHAR(SYSDATE,'yyyymmdd')) 

    ) akvi

    group by 
    DTAKVI_ID_BALICKU, 
    DTAKVI_D_PARTNER,
    DTAKVI_KOMODITA,
    DTAKVI_D_ID_OBJ

) a 
WHERE 
 MAX_PRIO_PROCES = 1 -- granulatita balíčku / PFI -- vždy pouze stav V_PROCESU v rámci balíčku.

), 

Logged_info AS (
-- pokud existuje partner, tak očekáváme, že byl někdo přihlášen, pokud ne, tak prihlasen nebyla bereme to jako cloveka co si jen z venku otevrel samoobsluhu

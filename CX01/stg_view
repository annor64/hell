             end   as utac01_d_ccatid3  
      ,utac01_d_mob_fl -- Mobil   
      ,ddbpar_d_osl_dop                  as utac01_d_osl_dop    
      ,decode(ddbpar_pohlavi,'M','1','Z','2','N',null,ddbpar_pohlavi) as utac01_pohlavi   

         when typ_retence = 'Reaktivní' and Trunc(vypr.datum_odhlaseni) > Trunc(VYPR.POZADOVANE_DAT_VYP_PRED)+16     then 'T9 Úspěšná'
--         when typ_retence = 'Reaktivní' and reak.DATUM_REAK_P02 is null                                                                              then '??? Reaktivní reak.DATUM_REAK_P02 is null ' 

              ,to_char(ti01.utti01_d_erdat,'YYYYMMDD')  as utti01_d_erdat
              ,to_char(ti01.utti01_d_datuza,'YYYYMMDD')  as utti01_d_datuza 
              ,ti01.utti01_d_ccatid1 -- >> utti01_d_ccatid1
              ,ti01.utti01_d_ccatid2 -- >> utti01_d_ccatid2
              ,nvl(ti01.utti01_d_direct,'N/A') as utti01_d_direct  
              ,ti01.utti01_d_kanal   
              ,decode(ti01.utti01_d_ele_fl,'N/A',null,ti01.utti01_d_ele_fl) as  utti01_d_ele_fl  
              ,ti01.utti01_d_partner 
              ,decode(ti01.utti01_ad02_tel,'N/A',null,ti01.utti01_ad02_tel) as utti01_ad02_tel  
              ,decode(ti01.utti01_d_ply_fl,'N/A',null,ti01.utti01_d_ply_fl) as utti01_d_ply_fl  
              ,decode(ti01.utti01_email,'N/A',null,ti01.utti01_email)       as utti01_email  


              ,ti01.utti01_d_zalozil_d_user 
              ,ti01.utti01_d_resitel_d_user 

              ,ti01.utti01_d_crm_uzs
              ,ti01.utti01_ddbpar_nazev     

              ,'P03' AS utti01_id_kpi  -- ID KPI	/ D_ID_KPI / I01
              ,ti01.utti01_vlastnik_dat     
              ,to_char(ti01.utti01_rozhodne_datum,'YYYYMMDD') as utti01_rozhodne_datum 
              ,ti01.utti01_d_ccatid3  -- utti01_d_ccatid3
              ,decode(ti01.utti01_d_mob_fl,'N/A',null,ti01.utti01_d_mob_fl)   as utti01_d_mob_fl         
              ,decode(ti01.utti01_d_osl_dop,'N/A',null,ti01.utti01_d_osl_dop) as utti01_d_osl_dop        
              ,ti01.utti01_pohlavi     
              ,ti01.utti01_varianta
              ,ti01.utti01_d_proctyp
              ,ti01.utti01_d_oth_fl
              ,row_number() over (partition by utti01_d_partner order by  ti01.utti01_d_activit desc) as utti01_poradi 
         from 
            OWNBT_STG.SUT_CX01_TI01_01_SOL_INIT_V ti01
            CROSS JOIN xfc 
        where 1=1 
           and not ti01.utti01_email is null
           -- offset definovan jako zaporne cislo 
           and trunc(xccpro_process_date + round(xccpro_date_offset_from,0))  = trunc(ti01.utti01_rozhodne_datum) 
     ) 
    where utti01_poradi = 1
;

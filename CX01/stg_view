    DTAKVI_OTNA01_D_ZMENIL_KPJM,
    DTAKVI_KOMODITA,

    OTCL05_D_GUIDIAF,
    OTCL05_D_EPMOBN,
    OTCL05_D_OBOR,
    OTCL05_ID,


    DDBPAR_NAZEV,
    ddbpar_d_osl_dop ,
    ddbpar_pohlavi  ,

    case when Logged_OTCL05_D_GUIDIAF is null then 'SAM' else 'COL' end as Logged

    from 
    GT_BASE bas

    INNER JOIN 
    ownbt_dwh.dsd_bpar bpar
    ON (bpar.ddbpar_d_partner = bas.DTAKVI_D_PARTNER and bpar.DDBPAR_CURRENT_FLAG = 1)
    inner join 
    OWNBT_ODS.ODT_SZD1 on ODT_SZD1.OTSZD1_CRM_NABIDKA_ID_OBJ = BAS.DTAKVI_D_ID_OBJ and ODT_SZD1.OTSZD1_CURRENT_FLAG = 1
    inner join
   OWNBT_ODS.ODT_CL05 on  ODT_CL05.OTCL05_D_GUIDIAF = ODT_SZD1.OTSZD1_RECORD_ID
                         and OTCL05_CURRENT_FLAG = 1 and OTCL05_D_CONSNR = 99
     left join Logged_info on ODT_CL05.OTCL05_D_GUIDIAF = Logged_info.Logged_OTCL05_D_GUIDIAF

    where  1=1
    and NVL(OTCL05_D_EPMOBN,'N/A') <> 'N/A' -- musí mít telefon
    AND DTAKVI_DATUM_P01 >= add_months(trunc(sysdate),-6) -- první datum P01 nesmí být starší než 180 dnů
    AND not DTAKVI_DATUM_P02 is null
 --   and DTAKVI_TYP_FIN_BUSINESS IN ('NOVY_NEBO_OBNOVENY_ODBER', 'NOVY_ODBER', 'OBNOVENY_ODBER', 'PREPIS_BEZ_ZD', 'PREPIS_SE_ZD', 'STANDARDNI_ZD') 
    -- výčet. nesmí tam být návaznost na neoprávněný odběr nebo nějaká heuristika 
) x
)



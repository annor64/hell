,
Otevrena_reklamace as
(
select 
            distinct OTAC01_D_PARTNER AS OP_OTEVRENA_REKLAMACE,
                     1 AS OTEVRENA_REKLAMACE_FVE_TEPC
            FROM OWNBT_ODS.ODT_AC01
            INNER JOIN OWNBT_ODS.ODC_CTID KAT2 ON OTAC01_D_CSCHID1 = KAT2.OCCTID_D_CSCHID AND KAT2.OCCTID_D_CCATID = OTAC01_D_CCATID2 AND KAT2.OCCTID_CURRENT_FLAG = 1 AND trunc (sysdate) between KAT2.OCCTID_DATEFROM AND KAT2.OCCTID_DATETO
            INNER JOIN OWNBT_ODS.ODC_CTID KAT3 ON OTAC01_D_CSCHID1 = KAT3.OCCTID_D_CSCHID AND KAT3.OCCTID_D_CCATID = OTAC01_D_CCATID3 AND KAT3.OCCTID_CURRENT_FLAG = 1 AND trunc (sysdate) between KAT3.OCCTID_DATEFROM AND KAT3.OCCTID_DATETO
            INNER JOIN OWNBT_ODS.ODC_CUZS ON OCCUZS_VALOBJ = OTAC01_D_CRM_UZS
            INNER JOIN OWNBT_ODS.ODC_CATE ON OCCATE_VALOBJ = OTAC01_D_CATEG
            WHERE   1 = 1
                    AND OTAC01_D_PROCTYP <> 'Z100'
                    AND OTAC01_CURRENT_FLAG = 1
                    AND OTAC01_D_PARTNER <> 'N/A' 
                    AND OTAC01_D_CCATID2 in ('REK_FVE', 'REK_OSTATNI', 'ZREKLAMACE', 'REK_TECH')
                    AND (OTAC01_D_CCATID3 in ('REK_OSTATNI_07') OR OTAC01_D_CCATID3 like '%REK_FVE%' OR OTAC01_D_CCATID3 like '%REK_TECH%') 
                    AND OCCUZS_TXTF in ('V řešení', 'Rozpracováno', 'Přijato od 3. strany', 'Přijato', 'Konzultace')     --pouze otev en  p  pady 
),
Historicka_reklamace as

(
SELECT  OTAC01_D_PARTNER AS OP_REKLAMACE_V_MINULOSTI,
                    sum(CASE WHEN KAT2.OCCTID_TXTF = 'Reklamace FVE' THEN  1 END) AS REKLAMACE_FVE,
                    sum(CASE WHEN KAT3.OCCTID_TXTF = 'Reklamace TČ (tepelné čerpadlo)' THEN  1 END) AS REKLAMACE_TEPC


            FROM OWNBT_ODS.ODT_AC01
            INNER JOIN OWNBT_ODS.ODC_CTID KAT2 ON OTAC01_D_CSCHID1 = KAT2.OCCTID_D_CSCHID AND KAT2.OCCTID_D_CCATID = OTAC01_D_CCATID2 AND KAT2.OCCTID_CURRENT_FLAG = 1 AND trunc (sysdate) between KAT2.OCCTID_DATEFROM AND KAT2.OCCTID_DATETO
            INNER JOIN OWNBT_ODS.ODC_CTID KAT3 ON OTAC01_D_CSCHID1 = KAT3.OCCTID_D_CSCHID AND KAT3.OCCTID_D_CCATID = OTAC01_D_CCATID3 AND KAT3.OCCTID_CURRENT_FLAG = 1 AND trunc (sysdate) between KAT3.OCCTID_DATEFROM AND KAT3.OCCTID_DATETO
            INNER JOIN OWNBT_ODS.ODC_CUZS ON OCCUZS_VALOBJ = OTAC01_D_CRM_UZS
            INNER JOIN OWNBT_ODS.ODC_CATE ON OCCATE_VALOBJ = OTAC01_D_CATEG
            WHERE   1 = 1
                    AND OTAC01_D_PROCTYP <> 'Z100'
                    AND OTAC01_CURRENT_FLAG = 1
                    AND OTAC01_D_PARTNER <> 'N/A' 
                    AND OTAC01_D_CCATID2 in ('REK_FVE', 'REK_OSTATNI', 'ZREKLAMACE', 'REK_TECH')
                    AND (OTAC01_D_CCATID3 in ('REK_OSTATNI_07') OR OTAC01_D_CCATID3 like '%REK_FVE%' OR OTAC01_D_CCATID3 like '%REK_TECH%') 
                    AND OCCUZS_TXTF in ('Uzavřeno', 'Storno', 'Předáno 3. straně', 'Odesláno vyrozumění')       --uzav en  reklamace v minulosti 
            group by OTAC01_D_PARTNER
)



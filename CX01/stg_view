from temp_leady_nasledky_cx ln

    join ownbt_ods.odd_user_v	odd_user_v1 on odd_user_v1.oduser_d_bp_user = ln.otac01_d_zalozil

    join ownbt_ods.odd_user_v	odd_user_v2 on odd_user_v2.oduser_d_bp_user = ln.otac01_d_resitel

    join ownbt_dwh.dsd_bpar                 on ln.otac01_d_partner       = ddbpar_d_partner and ddbpar_current_flag  =1

-- u retence zbytecne   join sut_cx01_zzz_sub_act_sml_01_mv act_sml          on ln.otac01_d_partner = act_sml.dfsmoa_isml_d_partner -- existuje platna smlouva

    left join OWNBT_STG.sut_cx01_zzz_sub_email_01_mv email  on ln.otac01_d_partner = email.Partner_email_hlavni

    left join OWNBT_STG.sut_cx01_zzz_sub_tel_01_mv tel    on ln.otac01_d_partner = tel.Partner_telefon_hlavni

    left join OWNBT_STG.sut_cx01_zzz_sub_gdpr_01_mv GDPR    on ln.otac01_d_partner = GDPR.ddbpar_d_partner

left join 
    temp_nabidky_zp_cx nab
    on  ln.ID_NO = nab.ID_NO
    AND ln.OP = nab.OP 
    AND ln.EAN_EIC = nab.EAN_EIC

left join     
    temp_vypovedi_po_nasledce_cx vypp
    on  ln.ID_NO = vypp.ID_NO
    AND ln.OP = vypp.OP 
    AND ln.EAN_EIC = vypp.EAN_EIC

left join 
    temp_vypovedi_pred_reakt_cx vypr
    on  ln.ID_NO = vypr.ID_NO
    AND ln.OP = vypr.OP 
    AND ln.EAN_EIC = vypr.EAN_EIC

left join 
    temp_nabidky_reak_cx reak
    on  ln.ID_NO = reak.ID_NO
    AND ln.OP = reak.OP 
    AND ln.EAN_EIC = reak.EAN_EIC

where 1=1 
and ln.typ_retence is not null and ln.ean_eic <> 'N/A'
and GDPR.ddbpar_d_partner is null
and not otac01_d_kanal = '31'  /*ŠČ*/
and         case 
            when typ_retence in ('Preventivní', 'Proaktivní') then  ln.DAT_ZALOZENI_NO +60
            when typ_retence = 'Reaktivní' then VYPR.POZADOVANE_DAT_VYP_PRED +16
            else NULL 
        end between sysdate -7 and sysdate


and not     case 
         when typ_retence = 'Preventivní' and vypp.ID_VYP_PO is not null and nab.ID_nabidka is null                                    then 'T4 Neúspěšná bez nabídky'
         when typ_retence = 'Preventivní' and vypp.ID_VYP_PO is not null and nab.ID_nabidka is not null                                then 'T2 Neúspěšná s nabídkou' 
         when typ_retence = 'Preventivní' and vypp.ID_VYP_PO is null     and nab.ID_nabidka is null                                    then 'T3 Úspěšná bez nabídky'
         when typ_retence = 'Preventivní' and vypp.ID_VYP_PO is null     and nab.ID_nabidka is not null and nab.DATUM_P08 is not null  then 'T1 Úspěšná s nabídkou' 
         when typ_retence = 'Proaktivní'  and vypp.ID_VYP_PO is not null and nab.ID_nabidka is null                                    then 'T8 Neúspěšná bez nabídky'
         when typ_retence = 'Proaktivní'  and vypp.ID_VYP_PO is not null and nab.ID_nabidka is not null                                then 'T6 Neúspěšná s nabídkou'         
         when typ_retence = 'Proaktivní'  and vypp.ID_VYP_PO is null     and nab.ID_nabidka is null                                    then 'T7 Úspěšná bez nabídky'
         when typ_retence = 'Proaktivní'  and vypp.ID_VYP_PO is null     and nab.ID_nabidka is not null and nab.DATUM_P08 is not null  then 'T5 Úspěšná s nabídkou'
         when typ_retence = 'Reaktivní' and reak.DATUM_REAK_P02 is not null then 'T9 Úspěšná'
         when typ_retence = 'Reaktivní' and Trunc(vypr.datum_odhlaseni) = Trunc(VYPR.POZADOVANE_DAT_VYP_PRED)        then 'T10 Neúspěšná'
         when typ_retence = 'Reaktivní' and Trunc(vypr.datum_odhlaseni) > Trunc(VYPR.POZADOVANE_DAT_VYP_PRED)+16     then 'T9 Úspěšná'
        else NULL end is null
)




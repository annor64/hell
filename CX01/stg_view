  WITH 
  GT_PROVEDEN AS (
-- hledam ten posledni stav, a z nich chci jen tyto dva, vypada to slozite, ale lepe to udelat neslo a ID v RN je protoze tam obcas byla duplicita, tak berem ten posledni.
    select 
        OTRS08_D_CRM_SES,
        OTRS08_D_ORDTYPE,
        OTRS08_D_PLANDAT,
        OTRS05_D_AEDAT,
        OTRS08_D_ORDSTAT 
        from (
                select 
                    OTRS08_D_CRM_SES,
                    OTRS08_D_ORDTYPE,
                    OTRS08_D_PLANDAT,
                    OTRS08_D_ORDSTAT,
                    OTRS05_D_AEDAT,
                    row_number() over (partition by OTRS08_D_CRM_SES order by OTRS08_D_PLANDAT desc, OTRS05_D_AEDAT desc ) as RN
                from OWNBT_ODS.ODT_RS08 
                inner join OWNBT_ODS.ODT_RS05
                on OTRS08_D_CSV_ZAK = OTRS05_D_CSV_ZAK
                    WHERE OTRS08_CURRENT_FLAG =1
                    and OTRS05_CURRENT_FLAG =1
                    and OTRS08_D_PLANDAT >sysdate -60
                )
            where RN = 1 
            and OTRS08_D_ORDSTAT in ('FINI','CONF')
),

  GT_STATUSY AS (
  
  
 select
    OTSS01_ID,
    OTSS01_D_PARTNER,
    OTSS01_d_CRM_SES,
    OTSS01_D_ID_OBJ ,
    OTSS01_D_CRM_SHS, 
    OTSS01_D_ERDAT,
    OTSS01_D_AEDAT,
    OTSS01_D_KANAL,
    OTSS01_D_CRM_UZS,
    OTSS01_D_ZALOZIL,
    OTSS01_D_ODPOVH,
    OTSS01_D_SES_TS,
    otss01_d_timezal,
    DATE_ROZHODNE_DATUM,
    OTSS01_D_CCATID1 as UTSS01_D_CCATID1,
    OTSS01_D_CCATID2 as UTSS01_D_CCATID2,
    OTSS01_D_CCATID3 as UTSS01_D_CCATID3
    from (
        --Aktivace: generujeme jenom jednou, tu prvn  zm nu statusu smlouvy na  Aktivn  (ZS_CSV0003), n sleduj c  statusy Aktivn  v historii smlouvy n s nezaj maj . Bereme datum ze sloupce D_AEDAT
    SELECT     
        OTSS01_ID,
        OTSS01_D_PARTNER,
        OTSS01_d_CRM_SES,
        OTSS01_D_ID_OBJ ,
        OTSS01_D_CRM_SHS, 
        OTSS01_D_ERDAT,
        OTSS01_D_AEDAT,
        OTSS01_D_KANAL,
        OTSS01_D_CRM_UZS,
        OTSS01_D_ZALOZIL,
        OTSS01_D_ODPOVH,
        OTSS01_D_SES_TS,
        otss01_d_timezal,  
        trunc(OTSS01_D_AEDAT) as DATE_ROZHODNE_DATUM,
        case when otss01_d_proctyp = 'ZSV1' then '990000'                                                 -- Original
             when otss01_d_proctyp = 'ZSF1' then '990000'                                                 -- FVE  
             when otss01_d_proctyp = 'ZSC1' then '990000'                                                 -- TC
        else  'N/A' end as OTSS01_D_CCATID1,
        case when otss01_d_proctyp = 'ZSV1' then '990200'                                                 -- Original
             when otss01_d_proctyp = 'ZSF1' then '990400'                                                 -- FVE  
             when otss01_d_proctyp = 'ZSC1' then '990300'                                                 -- TC
        else  'N/A' end as OTSS01_D_CCATID2,
        case when otss01_d_proctyp = 'ZSV1' then ''                                                 -- Original
             when otss01_d_proctyp = 'ZSF1' then ''                                                     -- FVE  
             when otss01_d_proctyp = 'ZSC1' then ''                                                     -- TC
        else  'N/A' end as OTSS01_D_CCATID3,
        ROW_NUMBER() OVER(PARTITION BY OTSS01_D_CRM_SES ORDER BY OTSS01_D_ERDAT) AS rn
         FROM ownbt_ods.odt_ss01
         WHERE otss01_d_crm_uzs like 'ZS_CS_0003' AND 
         (
             (otss01_d_prod = '001A4A1A089F1ED880C3D4B9A5691EA8' AND otss01_d_proctyp = 'ZSV1') /*Originalni servis*/ 
          or (otss01_d_prod = '001A4A1A0E101EDF919EE72DF15499EA' AND otss01_d_proctyp = 'ZSF1') /*FVE*/ 
          or (otss01_d_prod = '001A4A1A0E101EDF919F7744A6BA99EA' AND otss01_d_proctyp = 'ZSC1') /*TC*/      
         )
        ) where rn =1 and OTSS01_D_AEDAT - OTSS01_D_ERDAT<30 -- pridana podminka aby se nam to stale negenerovalo.




        --Terminovani  (UTAC01_D_CCATID3 - K078): generujeme tu prvn  zm nu statusu z ZS_CSV0003 na ZS_CSV0005 v dan m roce. Bereme datum ze sloupce D_AEDAT. Nezajima nas, pokud dojde ke zmene terminu.
          union 
          select     
            ss01_now.OTSS01_ID,
            ss01_now.OTSS01_D_PARTNER,
            ss01_now.OTSS01_d_CRM_SES,
            ss01_now.OTSS01_D_ID_OBJ ,
            ss01_now.OTSS01_D_CRM_SHS, 
            ss01_now.OTSS01_D_ERDAT,
            ss01_now.OTSS01_D_AEDAT,
            ss01_now.OTSS01_D_KANAL,
            ss01_now.OTSS01_D_CRM_UZS,
            ss01_now.OTSS01_D_ZALOZIL,
            ss01_now.OTSS01_D_ODPOVH,
            ss01_now.OTSS01_D_SES_TS,
            ss01_now.otss01_d_timezal,
            trunc(ss01_now.OTSS01_D_AEDAT) as DATE_ROZHODNE_DATUM,
            'L013' as UTSS01_D_CCATID1,
            'L160' as UTSS01_D_CCATID2,
            'K078' as UTSS01_D_CCATID3
                from   
                    ( select * from ownbt_ods.odt_ss01 where otss01_d_crm_uzs ='ZS_CSV0005'  AND OTSS01_D_PROD = '001A4A1A089F1ED880C3D4B9A5691EA8' and OTSS01_D_PROCTYP = 'ZSV1' and otss01_current_flag = 1 ) ss01_now
                    INNER JOIN
                    (select OTSS01_d_CRM_SES, otss01_valid_to  from ownbt_ods.odt_ss01 where otss01_d_crm_uzs ='ZS_CSV0003'  AND  OTSS01_D_PROD = '001A4A1A089F1ED880C3D4B9A5691EA8' and OTSS01_D_PROCTYP = 'ZSV1' and otss01_current_flag = 0 ) ss01_prev
                    ON ss01_prev.OTSS01_d_CRM_SES = ss01_now.OTSS01_d_CRM_SES 
                    and ss01_prev.otss01_valid_to + 1 = ss01_now.otss01_valid_From 

        --Proveden  servisu ((UTAC01_D_CCATID3   K150): generujeme tu prvn  zm nu statusu z ZS_CSV0005 na ZS_CSV0006 v dan m roce. Bereme datum ze zak zky (tato data jsou ulo en  v tabulce ZCSV_RS_ORDER, v parametru PLAN_DATE   viz n e).
        -- predelano, ze se data bedou podle rpovedeho servisu, tedy uz ne zmena 005 an 006
          union 
                   select       
            ss01_now.OTSS01_ID,
            ss01_now.OTSS01_D_PARTNER,
            ss01_now.OTSS01_d_CRM_SES,
            ss01_now.OTSS01_D_ID_OBJ ,
            ss01_now.OTSS01_D_CRM_SHS, 
            ss01_now.OTSS01_D_ERDAT,
            GT_PROVEDEN.OTRS08_D_PLANDAT as OTSS01_D_AEDAT, -- nastavuje se misto tohoto datumu, aby to bylo datum kdy ten clovek ta dosel
            ss01_now.OTSS01_D_KANAL,
            GT_PROVEDEN.OTRS08_D_ORDSTAT as OTSS01_D_CRM_UZS,
            ss01_now.OTSS01_D_ZALOZIL,
            ss01_now.OTSS01_D_ODPOVH,
            ss01_now.OTSS01_D_SES_TS,
            ss01_now.otss01_d_timezal,
            case 
                when GT_PROVEDEN.OTRS08_D_ORDTYPE = 'RSORD_REVI' then trunc(GT_PROVEDEN.OTRS08_D_PLANDAT) 
                when GT_PROVEDEN.OTRS08_D_ORDTYPE = 'RSORD_SERV' and OTRS08_D_ORDSTAT ='FINI' then trunc(GT_PROVEDEN.OTRS05_D_AEDAT) 
                else NULL -- je to ten kdyz servis neni fini
            end
            as DATE_ROZHODNE_DATUM, -- rozhodne datum je datum zmeny v systemu
            'L013' as UTSS01_D_CCATID1,

            case when otss01_d_proctyp = 'ZSV1' then 'L160'                                                 -- Original
                 when otss01_d_proctyp = 'ZSF1' then 'L194'                                                 -- FVE  
                 when otss01_d_proctyp = 'ZSC1' then 'L195'                                                 -- TC
            else  'N/A' end as UTSS01_D_CCATID2,

            case when otss01_d_proctyp = 'ZSV1' and GT_PROVEDEN.OTRS08_D_ORDTYPE ='RSORD_SERV' then 'K151'  -- Original
                 when otss01_d_proctyp = 'ZSV1' then 'K150'                                                 -- Original
                 when otss01_d_proctyp = 'ZSF1' and GT_PROVEDEN.OTRS08_D_ORDTYPE ='RSORD_SERV' then 'K153'  -- FVE
                 when otss01_d_proctyp = 'ZSF1' then 'K152'                                                 -- FVE  
                 when otss01_d_proctyp = 'ZSC1' and GT_PROVEDEN.OTRS08_D_ORDTYPE ='RSORD_SERV' then 'K155'  -- TC 
                 when otss01_d_proctyp = 'ZSC1' then 'K154'                                                 -- TC
            else  'N/A'
            end as UTSS01_D_CCATID3
            --            OTRS08_D_ORDTYPE,
                from   
                ( select * from ownbt_ods.odt_ss01 where    (
                   ( otss01_d_prod = '001A4A1A089F1ED880C3D4B9A5691EA8' AND otss01_d_proctyp = 'ZSV1') /*Originalni servis*/ 
                or ( otss01_d_prod = '001A4A1A0E101EDF919EE72DF15499EA' AND otss01_d_proctyp = 'ZSF1') /*FVE*/ 
                or ( otss01_d_prod = '001A4A1A0E101EDF919F7744A6BA99EA' AND otss01_d_proctyp = 'ZSC1') /*TC*/ )
                ) ss01_now
                    inner join 
                    GT_PROVEDEN on GT_PROVEDEN.OTRS08_D_CRM_SES = ss01_now.OTSS01_d_CRM_SES
                    and GT_PROVEDEN.OTRS08_D_PLANDAT between to_date(ss01_now.otss01_valid_From,'YYYYMMDD') and to_date(ss01_now.otss01_valid_To,'YYYYMMDD')



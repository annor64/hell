----------LEADY -- napojuji kvůli rozdělení na proaktivní a preventivní retenci

temp_leady_nasledky_cx as
(
select
    na.*,

    LE."ID objektu" ID_LEAD,
    LE."Typ akce" TYP_LEADU,
    LE."Text Leadu" POPIS_LEADU,
    LE."Odp.os._Uživatel" RESITEL_LEADU,
    LE."První hovor - Dovoláno dne" DOVOLANO_DNE,

-- typ retence rozlišuji u prevence a aktivky dle leadu, reaktivní jsou všechny V096
    case when NA.KATEGORIE_3 = 'V096' then 'Reaktivní'
         when lower(le."Text Leadu")  like '%prevence%' then 'Preventivní'
         when le."Typ akce" =  'PRR - Proaktivní retence' then 'Proaktivní'
         else null end as TYP_RETENCE 

from temp_nasledky_cx na

left join
     BR.LEADY_DATA_T LE -- leady
     on NA.OP = lpad(LE."Zájemce", 10 ,'0') 
     and LE."Datum založení" >= to_date('01.03.2024', 'DD.MM.YYYY')
     and NA.ZALOZIL_NO_KPJM = LE."Odp.os._Uživatel" -- zakladatel následky musí být stejný jako řešitel leadu
     --and NA.KATEGORIE_3 in ('E018', 'E019') -- leady napujuji jen k následkám aktivky a prevence 
     --and ( LE."Typ akce" = 'PRR - Proaktivní retence' -- proaktivní retence
       --     or lower(LE."Text Leadu")  like '%prevence%' ) --prevence
     and NA.DAT_ZALOZENI_NO = LE."První hovor - Dovoláno dne" 
)
,   

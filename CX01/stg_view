),



/* NYNÍ PROVEDEME RŮZNÉ VARIANTY PROPOJENÍ POŽADAVKU NA NÁSLEDNOU OPERACI s dodatečnými atributy */

GT_PREOUT AS (
-- toto něco vybere --
SELECT 
    propojenino.otac02_d_activip as OTAC01_D_ACTIVIT,
    email.OTAC01_D_EMAILOS
FROM
GT_REL_NASLEDNA_OPERACE  propojeniemail
INNER JOIN GT_EMAILY email                
    on (propojeniemail.otac02_d_activip  = email.OTAC01_D_ACTIVIT)
INNER JOIN GT_REL_NASLEDNA_OPERACE propojenino 
    on (propojeniemail.OTAC02_D_ID_OBJ   = propojenino.OTAC02_D_ID_OBJ)

UNION ALL

-- toto mi nic nevybralo, ale mám to prý zachovat --
SELECT
    propojeni.OTAC02_D_ACTIVIT  as OTAC01_D_ACTIVIT,
    email.OTAC01_D_EMAILOS
FROM
    GT_EMAILY email
INNER JOIN  GT_REL_NASLEDNA_OPERACE propojeni 
    on (email.OTAC01_D_ID_OBJ = propojeni.OTAC02_D_ID_OBJ)


UNION ALL


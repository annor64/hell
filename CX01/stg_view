  WITH xfc as
 (
 select xccpro_key, xccpro_filename_templ, xccpro_filename_key, xccpro_filename_date,XCCPRO_DATE_OFFSET_FROM,XCCPRO_PROCESS_DATE
 from bisupport.xfc_cpro      
        where xccpro_key = 'CAWI_CX01_TI01_01_D1'        
           and xccpro_current_flag = 1
)

select 
  utti01_xccpro_key
, utti01_export_filename
, utti01_id
, utti01_effective_date
, utti01_d_activit
, utti01_d_id_obj
, utti01_d_erdat
, utti01_d_datuza
 ,null as utti01_timezal
, utti01_d_ccatid1
, utti01_d_ccatid2
, utti01_d_direct
, utti01_d_kanal
, utti01_d_ele_fl
, utti01_d_partner
, utti01_ad02_tel
, utti01_d_ply_fl
,null as utti01_d_telnvo
, utti01_email
,null as utti01_adresa_ulice
,null as utti01_adresa_cp   
,null as utti01_adresa_co   
,null as utti01_adresa_misto
,null as utti01_adresa_mistni_cast
,null as utti01_adresa_psc 
, utti01_d_zalozil_d_user
, utti01_d_resitel_d_user
,null as utti01_pocet_resitelu  
, utti01_d_crm_uzs
, utti01_ddbpar_nazev
,null as utti01_bonita          
,null as utti01_segmentace      
,null as utti01_pocet_ms        
,null as utti01_odhad_spotreby  
,null as utti01_hodnota_zakaznika
, utti01_pracoviste  
, utti01_id_kpi
, utti01_vlastnik_dat
, utti01_rozhodne_datum
, utti01_d_ccatid3
, utti01_d_mob_fl
, utti01_d_osl_dop
, utti01_pohlavi
, utti01_varianta
, utti01_d_proctyp
, utti01_d_oth_fl
    from (
        select distinct xccpro_key as utti01_xccpro_key
              ,xccpro_filename_templ||'_'||replace(xccpro_filename_key,'YYYYMMDD',to_char(xccpro_filename_date,'YYYYMMDD')) as utti01_export_filename
              ,utti01_id 
              ,to_char(xccpro_process_date,'YYYYMMDD')  as utti01_effective_date
              ,ti01.utti01_d_activit 
              ,ti01.utti01_d_id_obj  
              ,to_char(ti01.utti01_d_erdat,'YYYYMMDD')  as utti01_d_erdat
              ,to_char(ti01.utti01_d_datuza,'YYYYMMDD')  as utti01_d_datuza 
              ,ti01.utti01_d_ccatid1 -- >> utti01_d_ccatid1
              ,ti01.utti01_d_ccatid2 -- >> utti01_d_ccatid2
              ,nvl(ti01.utti01_d_direct,'N/A') as utti01_d_direct  
              ,ti01.utti01_d_kanal   
              ,decode(ti01.utti01_d_ele_fl,'N/A',null,ti01.utti01_d_ele_fl) as  utti01_d_ele_fl  
              ,ti01.utti01_d_partner 
              ,decode(ti01.utti01_ad02_tel,'N/A',null,ti01.utti01_ad02_tel) as utti01_ad02_tel  
              ,decode(ti01.utti01_d_ply_fl,'N/A',null,ti01.utti01_d_ply_fl) as utti01_d_ply_fl  
              ,decode(ti01.utti01_email,'N/A',null,ti01.utti01_email)       as utti01_email  


              ,ti01.utti01_d_zalozil_d_user 
              ,ti01.utti01_d_resitel_d_user 

              ,ti01.utti01_d_crm_uzs
              ,ti01.utti01_ddbpar_nazev     
	          ,ti01.utti01_id_kpi    
              ,ti01.utti01_vlastnik_dat     
              ,to_char(ti01.utti01_rozhodne_datum,'YYYYMMDD') as utti01_rozhodne_datum 
              ,ti01.utti01_d_ccatid3  -- utti01_d_ccatid3
              ,decode(ti01.utti01_d_mob_fl,'N/A',null,ti01.utti01_d_mob_fl)   as utti01_d_mob_fl         
              ,decode(ti01.utti01_d_osl_dop,'N/A',null,ti01.utti01_d_osl_dop) as utti01_d_osl_dop        
              ,ti01.utti01_pohlavi     
              ,ti01.utti01_varianta
              ,ti01.utti01_d_proctyp
              ,ti01.utti01_d_oth_fl
              ,case when substr(OTBP13_D_USER,1,3) = 'QP3' then OTBP13_D_USER else 'N/A' end as utti01_pracoviste
              ,row_number() over (partition by utti01_d_partner order by  ti01.utti01_d_activit desc) as utti01_poradi 
         from 
            OWNBT_STG.SUT_CX01_TI01_01_INIT_V ti01
                left join  ownbt_ods.odt_ti02  on
            odt_ti02.otti02_d_crm_ti = ti01.utti01_d_activit 
            and otti02_current_flag = 1
        left join OWNBT_ODS.odt_nac1
                on otti02_d_crm_nab = OTNAC1_d_crm_nab  
                and otnac1_current_flag = 1
                and OTNAC1_D_NABV = 'X'
                and OTNAC1_D_PIMPD is not null

         left join OWNBT_ODS.odt_bp13
                on odt_bp13.otbp13_current_flag = 1
                AND odt_nac1.OTNAC1_D_DATEOR1 = odt_bp13.OTBP13_D_DATEORG
                AND odt_nac1.OTNAC1_D_PRODEJC = odt_bp13.OTBP13_D_BP_USEN

            CROSS JOIN xfc 
        where 1=1 
           and not ti01.utti01_email is null
           and 
           (
                ti01.utti01_d_datuza - ti01.utti01_d_erdat < 30 -- pridano extra, dle darka se to bude zase odstranovat
                or 
                ti01.utti01_d_ccatid1||'-'||ti01.utti01_d_ccatid2||'-'||ti01.utti01_d_ccatid3||'-'||ti01.utti01_d_crm_uzs
                in 
                    (
                        '010000-010100-010102-SZD_DONE'          -- Smlouvy - Nov  smlouva - Zm?na dodavatele - Po adavek vy e en
                       ,'010000-010100-010104-ZDPR_DONE'         -- Smlouvy - Nov  smlouva - ZD s p episem - Po adavek vy e en
                    ) 
                or
                    ti01.utti01_d_ccatid1||'-'||ti01.utti01_d_ccatid2
                in 
                    (
                        '990000-990100'          
                    ) 
           )
           -- offset definovan jako zaporne cislo 
        and trunc(xccpro_process_date + round(xccpro_date_offset_from,0)) -1 = trunc(ti01.utti01_rozhodne_datum) 
        and not utti01_d_crm_uzs ='MOU_02'
     ) 

    where utti01_poradi = 1
;

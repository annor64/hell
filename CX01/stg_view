    OWNBT_ODS.ODT_IPOD IPOD
    on  IPOD.OTIPOD_CURRENT_FLAG = 1 
    and ER.OTER01_D_EXTREF = IPOD.OTIPOD_D_ISU_POD

where
    1=1
    and AC.OTAC01_CURRENT_FLAG = 1   
    and AC.OTAC01_D_PROCTYP = 'ZSQT' 
    and AC.OTAC01_D_CCATID3 in ('E018', 'E019', 'V096') 

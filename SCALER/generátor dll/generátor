$Timestamp = Get-Date -Format "dd.MM.yyyy HH:mm:ss"
$MetaDescriptions = @{
    "ID"               = "Interní technické ID záznamu (sekvence)"
    "ORIG_ID"          = "Původní ID záznamu ze zdrojového systému"
    "EFFECTIVE_DATE"   = "Datum účinnosti dat (YYYYMMDD)"
    "CREATED_DATE"     = "Datum vložení záznamu do DB"
    "CREATED_PROCESS"  = "ID procesu/runu, který záznam vytvořil"
    "MODIFIED_DATE"    = "Datum poslední aktualizace záznamu"
    "MODIFIED_PROCESS" = "ID procesu/runu, který aktualizoval záznam"
    "VALID_FROM"       = "Začátek platnosti záznamu (YYYYMMDD)"
    "VALID_TO"         = "Konec platnosti záznamu (YYYYMMDD)"
    "CURRENT_FLAG"     = "Příznak aktuálně platného záznamu (1=ano)"
}

function Map-To-OracleType {
    param ($row)
    switch ($row.data_type) {
        "int"        { "NUMBER(10)" }
        "bigint"     { "NUMBER(19)" }
        "tinyint"    { "NUMBER(3)" }
        "bit"        { "NUMBER(1)" }
        "decimal"    { "NUMBER($($row.precision),$($row.scale))" }
        "numeric"    { "NUMBER($($row.precision),$($row.scale))" }
        "nvarchar"   { if ([int]$row.max_length -eq -1 -or [int]$row.max_length -gt 4000) {"CLOB"} else {"VARCHAR2($($row.max_length) CHAR)"}}
        "varchar"    { if ([int]$row.max_length -eq -1 -or [int]$row.max_length -gt 4000) {"CLOB"} else {"VARCHAR2($($row.max_length) CHAR)"}}
        "sysname"    { "VARCHAR2(128 CHAR)" }
        "char"       { "CHAR($($row.max_length))" }
        "float"      { "NUMBER" }
        "real"       { "NUMBER" }
        "datetime2"  { "TIMESTAMP" }
        "datetime"   { "TIMESTAMP" }
        "date"       { "DATE" }
        "varbinary"  { "BLOB" }
        default      { throw "Neznámý datový typ: $($row.data_type)" }
    }
}

$Schemas = @{ EXT_IMPORT = "XT"; OWNBT_INT = "IT"; OWNBT_ODS = "OT" }
$LeadingMetaColumns = @{ OWNBT_INT = 'PREFIX_EFFECTIVE_DATE NUMBER(8,0) NOT NULL'; OWNBT_ODS = 'PREFIX_ID NUMBER' }
$TrailingMetaColumns = @{
    EXT_IMPORT = @('PREFIX_CREATED_DATE DATE','PREFIX_CREATED_PROCESS VARCHAR2(100 CHAR)')
    OWNBT_INT  = @('PREFIX_CREATED_DATE DATE','PREFIX_CREATED_PROCESS VARCHAR2(100 CHAR)')
    OWNBT_ODS  = @('PREFIX_CREATED_DATE DATE','PREFIX_CREATED_PROCESS NUMBER','PREFIX_MODIFIED_DATE DATE','PREFIX_MODIFIED_PROCESS NUMBER','PREFIX_VALID_FROM NUMBER(8,0) NOT NULL','PREFIX_VALID_TO NUMBER(8,0)','PREFIX_CURRENT_FLAG NUMBER(1,0)')
}

$OutputFolder = ".\output"
if (!(Test-Path $OutputFolder)) { New-Item -ItemType Directory -Path $OutputFolder | Out-Null }
$Meta = Import-Csv $InputMetadata

# --- INICIALIZACE SOUBORŮ ---
foreach ($sh in $Schemas.Keys) {
    $filePath = Join-Path $OutputFolder "$sh.sql"
    @"
--------------------------------------------------------------------------------
-- Schema:    $sh
-- Generated: $Timestamp
-- Area:      $Area
--------------------------------------------------------------------------------

"@ | Out-File $filePath -Encoding UTF8 -Force 
}

$ViewFilePath = Join-Path $OutputFolder "OWNBT_ODS_VIEWS.sql"
@"
--------------------------------------------------------------------------------
-- Schema:    OWNBT_ODS (VIEWS)
-- Generated: $Timestamp
-- Area:      $Area
--------------------------------------------------------------------------------

"@ | Out-File $ViewFilePath -Encoding UTF8 -Force

# --- HLAVNÍ CYKLUS ---
$Meta | Group-Object table_name | ForEach-Object {
    $table = $_.Name; $rows = $_.Group; $code = $EntityCode[$table]
    if (-not $code) { return }

    foreach ($schema in $Schemas.Keys) {
        $prefix = $Schemas[$schema] + $code
        $tableName = switch ($schema) { "EXT_IMPORT" { "${Area}T_$code" }; "OWNBT_INT" { "INT_${Area}_$code" }; "OWNBT_ODS" { "ODT_${Area}_$code" } }
        $ddl = @(); $comments = @(); $currentPKs = @(); $allColumns = @(); $viewComments = @()

        # 1. SEKVENCE (ODS)
        if ($schema -eq "OWNBT_ODS") {
            $seqName = $Schemas[$schema] + $Area + "_" + $code + "_ID_SEQ"
            $ddl += "-- Sequence for $tableName"
            $ddl += "CREATE SEQUENCE $schema.$seqName MINVALUE 1 MAXVALUE 9999999999999999999999999999 INCREMENT BY 1 START WITH 1 CACHE 20 NOORDER NOCYCLE NOKEEP NOSCALE GLOBAL;`n"
        }

        # 2. TABULKA START
        $ddl += "-- Table: $tableName"
        $ddl += "CREATE TABLE $schema.$tableName ("
        
        # Leading Meta
        if ($LeadingMetaColumns.ContainsKey($schema)) {
            $colDef = $LeadingMetaColumns[$schema] -replace "PREFIX", $prefix
            $ddl += "    $colDef,"
            $colName = ($colDef -split ' ')[0]; $allColumns += $colName
            
            # Pokud jsme v INT nebo ODS, metadatový sloupec je částí PK
            if ($schema -eq "OWNBT_INT") { $currentPKs += $colName }
            elseif ($schema -eq "OWNBT_ODS" -and $colName -like "*ID") { 
                # Metadatové ID v ODS obvykle není PK (PK je ORIG_ID + VALID_FROM), 
                # ale pokud ho chcete jako PK, odkomentujte řádek níže:
                # $currentPKs += $colName 
            }

            $key = $colName -replace "^${prefix}_", ""
            if ($MetaDescriptions.ContainsKey($key)) { 
                $comments += "COMMENT ON COLUMN $schema.$tableName.$colName IS '$($MetaDescriptions[$key])';" 
            }
        }

        # Datové sloupce ze zdroje
        foreach ($r in $rows) {
            if ($r.is_computed -eq "True") { continue }
            
            $origColName = $r.column_name.ToUpper()
            
            # Přejmenování ID na ORIG_ID v ODS
            $finalColName = if ($schema -eq "OWNBT_ODS" -and $origColName -eq "ID") { "ORIG_ID" } else { $origColName }
            
            $columnName = "${prefix}_$finalColName"
            $allColumns += $columnName
            $type = Map-To-OracleType $r
            $null = if ($r.is_nullable -eq "False" -or $r.is_nullable -eq "0") { " NOT NULL" } else { "" }
            $ddl += "    $columnName $type$null,"
            
            # SBÍRÁNÍ PK ZE ZDROJE
            if ($r.is_primary_key -eq "1" -or $r.is_primary_key -eq "True") { 
                $currentPKs += $columnName 
            }
            
            $comm = if (![string]::IsNullOrEmpty($r.column_comment)) { $r.column_comment } else { $MetaDescriptions[$finalColName] }
            if ($comm) { 
                $comments += "COMMENT ON COLUMN $schema.$tableName.$columnName IS '$($comm -replace "'", "''")';" 
            }
        }

        # Trailing Meta
        foreach ($meta in $TrailingMetaColumns[$schema]) {
            $colDef = $meta -replace "PREFIX", $prefix
            $colName = ($colDef -split ' ')[0]; $allColumns += $colName
            $ddl += "    $colDef,"
            
            # VALID_FROM je v ODS součástí primárního klíče
            if ($schema -eq "OWNBT_ODS" -and $colName -like "*VALID_FROM") {
                $currentPKs += $colName
            }

            $key = $colName -replace "^${prefix}_", ""
            if ($MetaDescriptions.ContainsKey($key)) { 
                $comments += "COMMENT ON COLUMN $schema.$tableName.$colName IS '$($MetaDescriptions[$key])';" 
            }
        }

        $ddl[-1] = $ddl[-1].TrimEnd(',')
        if ($schema -eq "OWNBT_INT") {
            $ddl += @"
)
PARTITION BY RANGE (${prefix}_EFFECTIVE_DATE)
INTERVAL (1)
(
    PARTITION p0 VALUES LESS THAN (20100000)
)
;
"@
        } else {
            $ddl += ");"
        }

        # Komentář k tabulce
        $baseTableComment = if ($TableDescriptions.ContainsKey($table)) { $TableDescriptions[$table] } else { "Zdrojová tabulka $table (VCELKA)" }
        $ddl += "COMMENT ON TABLE $schema.$tableName IS '$baseTableComment';"

        # --- GENEROVÁNÍ PK ---
        if ($schema -eq "OWNBT_ODS" -and $currentPKs.Count -gt 0) {
            $ddl += "ALTER TABLE $schema.$tableName ADD CONSTRAINT PK_$tableName PRIMARY KEY ($($currentPKs -join ', '));"
        }

        if ($comments) { $ddl += $comments }

        if ($schema -eq "EXT_IMPORT") {
            $ddl += "GRANT DELETE, INDEX, ALTER, INSERT, SELECT, UPDATE ON $schema.$tableName TO OWNER_ETL;"
            $ddl += "GRANT SELECT ON $schema.$tableName TO ETL_PROVOZ;"
        }

        # Zápis do INZ_INDE pro INT tabulky
        if ($schema -eq "OWNBT_INT") {
            $ddl += "INSERT INTO ""OWNBT_INT"".""INZ_INDE"" VALUES ('$tableName', '${prefix}_PK', 'CREATE UNIQUE INDEX ${prefix}_PK ON $tableName ($($currentPKs -join ', ')) LOCAL UNUSABLE', TO_DATE('$Timestamp', 'DD.MM.YYYY HH24:MI:SS'), '');"
        }

        $ddl += ""
        Add-Content (Join-Path $OutputFolder "$schema.sql") ($ddl -join "`n")

        # View pouze pro ODS
        if ($schema -eq "OWNBT_ODS") {
            $viewName = "${tableName}_V"
            $v = @()
            $v += "CREATE OR REPLACE FORCE EDITIONABLE VIEW $schema.$viewName AS SELECT"
            $v += "    " + ($allColumns -join ",`n    ")
            $v += "FROM $schema.$tableName WHERE ${prefix}_CURRENT_FLAG = 1;"
            Add-Content $ViewFilePath ($v -join "`n")
        }
    }
}

# --- ZÁVĚREČNÁ ŽEHLIČKA ---
foreach ($schema in $Schemas.Keys) {
    if ($schema -ne "EXT_IMPORT") {
        $filePath = Join-Path $OutputFolder "$schema.sql"
        "`nexec refresh_owner_roles;" | Add-Content -Path $filePath -Encoding UTF8
    }
}


CREATE OR REPLACE FORCE EDITIONABLE VIEW "OWNBT_ODS"."V_ODT_FLX_FCDE_CURRENT_C" (
    OTFCDE_ID, OTFCDE_ORIG_ID, OTFCDE_COMMUNICATION_ID, OTFCDE_DEVICE_ID_CRM, OTFCDE_SUPPLY_POINT_ID, 
    OTFCDE_TYPE, OTFCDE_TYPE_TXTF, OTFCDE_PRODUCER, OTFCDE_PRODUCER_TXTF, OTFCDE_SERIAL_NUMBER, 
    OTFCDE_MODEL, OTFCDE_MODEL_TXTF, OTFCDE_VALID_FROM_UTC, OTFCDE_VALID_TO_UTC, OTFCDE_STATE, 
    OTFCDE_STATE_TXTF, OTFCDE_STATUS, OTFCDE_STATUS_TXTF, OTFCDE_MAX_OVERFLOW, OTFCDE_ONLINE, 
    OTFCDE_MANAGEMENT_ENABLED, OTFCDE_LAST_COMMUNICATION_AT_UTC, OTFCDE_LAST_MESSAGE_AT_UTC, 
    OTFCDE_CREATED_AT_UTC, OTFCDE_UPDATED_AT_UTC, OTFCDE_SAP_SYNCED_AT_UTC, OTFCDE_SAP_VALID_FROM_UTC, 
    OTFCDE_SAP_VALID_TO_UTC, OTFCDE_DELETED, OTFCDE_CONTROL_STATUS, OTFCDE_CONTROL_STATUS_TXTF, 
    OTFCDE_CONTROL_STATUS_CHANGED_UTC, OTFCDE_OUTFLOW_CONTROL_STATUS, OTFCDE_OUTFLOW_CONTROL_STATUS_TXTF, 
    OTFCDE_OUTFLOW_CONTROL_STATUS_CHANGED_UTC, OTFCDE_CREATED_DATE, OTFCDE_CREATED_PROCESS, 
    OTFCDE_MODIFIED_DATE, OTFCDE_MODIFIED_PROCESS, OTFCDE_VALID_FROM, OTFCDE_VALID_TO, OTFCDE_CURRENT_FLAG
) AS
(
SELECT
    t1.OTFCDE_ID,
    t1.OTFCDE_ORIG_ID,
    t1.OTFCDE_COMMUNICATION_ID,
    t1.OTFCDE_DEVICE_ID_CRM,
    t1.OTFCDE_SUPPLY_POINT_ID,

    -- Typ zařízení (TP_DVC -> FDVC)
    t1.OTFCDE_TYPE,
    t2.FDVC_TXTF AS OTFCDE_TYPE_TXTF, 

    -- Výrobce zařízení (TP_DVC_PRODUCER -> FDPR)
    t1.OTFCDE_PRODUCER,
    t3.FDPR_TXTF AS OTFCDE_PRODUCER_TXTF, 

    t1.OTFCDE_SERIAL_NUMBER,

    -- Model zařízení (TP_DVC_MODL -> FDMO)
    t1.OTFCDE_MODEL,
    t4.FDMO_TXTF AS OTFCDE_MODEL_TXTF, 

    t1.OTFCDE_VALID_FROM_UTC,
    t1.OTFCDE_VALID_TO_UTC,

    -- Technický stav (TP_DVC_STAT - DeviceState -> FDST)
    t1.OTFCDE_STATE,
    t5.FDST_TXTF AS OTFCDE_STATE_TXTF, 

    -- Obchodní status (TP_DVC_TECH_STAT -> FTEC)
    t1.OTFCDE_STATUS,
    t6.FTEC_TXTF AS OTFCDE_STATUS_TXTF, 

    t1.OTFCDE_MAX_OVERFLOW,
    t1.OTFCDE_ONLINE,
    t1.OTFCDE_MANAGEMENT_ENABLED,
    t1.OTFCDE_LAST_COMMUNICATION_AT_UTC,
    t1.OTFCDE_LAST_MESSAGE_AT_UTC,
    t1.OTFCDE_CREATED_AT_UTC,
    t1.OTFCDE_UPDATED_AT_UTC,
    t1.OTFCDE_SAP_SYNCED_AT_UTC,
    t1.OTFCDE_SAP_VALID_FROM_UTC,
    t1.OTFCDE_SAP_VALID_TO_UTC,
    t1.OTFCDE_DELETED,

    -- Stav řízení (TP_DVC_STAT - DeviceAvailabilityStatus -> FDST)
    t1.OTFCDE_CONTROL_STATUS,
    t7.FDST_TXTF AS OTFCDE_CONTROL_STATUS_TXTF, 

    t1.OTFCDE_CONTROL_STATUS_CHANGED_UTC,

    -- Stav řízení odtoku (TP_DVC_STAT - DeviceAvailabilityStatus -> FDST)
    t1.OTFCDE_OUTFLOW_CONTROL_STATUS,
    t8.FDST_TXTF AS OTFCDE_OUTFLOW_CONTROL_STATUS_TXTF, 

    t1.OTFCDE_OUTFLOW_CONTROL_STATUS_CHANGED_UTC,
    t1.OTFCDE_CREATED_DATE,
    t1.OTFCDE_CREATED_PROCESS,
    t1.OTFCDE_MODIFIED_DATE,
    t1.OTFCDE_MODIFIED_PROCESS,
    t1.OTFCDE_VALID_FROM,
    t1.OTFCDE_VALID_TO,
    t1.OTFCDE_CURRENT_FLAG

FROM
    OWNBT_ODS.ODT_FLX_FCDE t1

-- 1. OTFCDE_TYPE -> ODC_MDM_FDVC (TP_DVC)
LEFT OUTER JOIN OWNBT_ODS.ODC_MDM_FDVC t2
    ON (t2.FDVC_VALOBJ = t1.OTFCDE_TYPE)
-- 2. OTFCDE_PRODUCER -> ODC_MDM_FDPR (TP_DVC_PRODUCER)
LEFT OUTER JOIN OWNBT_ODS.ODC_MDM_FDPR t3
    ON (t3.FDPR_VALOBJ = t1.OTFCDE_PRODUCER)
-- 3. OTFCDE_MODEL -> ODC_MDM_FDMO (TP_DVC_MODL)
LEFT OUTER JOIN OWNBT_ODS.ODC_MDM_FDMO t4
    ON (t4.FDMO_VALOBJ = t1.OTFCDE_MODEL)
-- 4. OTFCDE_STATE -> ODC_MDM_FDST (TP_DVC_STAT - DeviceState)
LEFT OUTER JOIN OWNBT_ODS.ODC_MDM_FDST t5
    ON (t5.FDST_VALOBJ = t1.OTFCDE_STATE)
-- 5. OTFCDE_STATUS -> ODC_MDM_FTEC (TP_DVC_TECH_STAT - Status Flexibilty)
LEFT OUTER JOIN OWNBT_ODS.ODC_MDM_FTEC t6
    ON (t6.FTEC_VALOBJ = t1.OTFCDE_STATUS)
-- 6. OTFCDE_CONTROL_STATUS -> ODC_MDM_FDST (TP_DVC_STAT - DeviceAvailabilityStatus)
LEFT OUTER JOIN OWNBT_ODS.ODC_MDM_FDST t7
    ON (t7.FDST_VALOBJ = t1.OTFCDE_CONTROL_STATUS)
-- 7. OTFCDE_OUTFLOW_CONTROL_STATUS -> ODC_MDM_FDST (TP_DVC_STAT - DeviceAvailabilityStatus)
LEFT OUTER JOIN OWNBT_ODS.ODC_MDM_FDST t8
    ON (t8.FDST_VALOBJ = t1.OTFCDE_OUTFLOW_CONTROL_STATUS)

WHERE
    t1.OTFCDE_CURRENT_FLAG = 1
    AND t1.OTFCDE_DELETED = 0
);